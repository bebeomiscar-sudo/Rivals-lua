local TabsData  = {}
local ActiveTab = nil

local function CreateTab(name, icon)
    local tb = Instance.new("TextButton")
    tb.Size=UDim2.new(1,0,0,40); tb.BackgroundColor3=Theme.TabInactive
    tb.BorderSizePixel=0; tb.Text=icon.."  "..name; tb.TextColor3=Theme.TextDim
    tb.TextSize=13; tb.Font=Enum.Font.GothamBold
    tb.TextXAlignment=Enum.TextXAlignment.Left; tb.ZIndex=12; tb.Parent=TabBar
    Instance.new("UICorner",tb).CornerRadius=UDim.new(0,10)
    local tp=Instance.new("UIPadding"); tp.PaddingLeft=UDim.new(0,12); tp.Parent=tb

    local ab=Instance.new("Frame")
    ab.Size=UDim2.new(0,3,0.6,0); ab.Position=UDim2.new(0,-1,0.2,0)
    ab.BackgroundColor3=Theme.Accent; ab.BorderSizePixel=0; ab.Visible=false; ab.ZIndex=13; ab.Parent=tb
    Instance.new("UICorner",ab).CornerRadius=UDim.new(1,0)

    local tc=Instance.new("ScrollingFrame")
    tc.Name=name.."Content"; tc.Size=UDim2.new(1,0,1,0)
    tc.BackgroundTransparency=1; tc.BorderSizePixel=0
    tc.ScrollBarThickness=3; tc.ScrollBarImageColor3=Theme.Accent
    tc.CanvasSize=UDim2.new(0,0,0,0); tc.AutomaticCanvasSize=Enum.AutomaticSize.Y
    tc.Visible=false; tc.ZIndex=12; tc.Parent=ContentArea

    local cl=Instance.new("UIListLayout"); cl.SortOrder=Enum.SortOrder.LayoutOrder; cl.Padding=UDim.new(0,6); cl.Parent=tc
    local cp=Instance.new("UIPadding")
    cp.PaddingTop=UDim.new(0,12); cp.PaddingLeft=UDim.new(0,10)
    cp.PaddingRight=UDim.new(0,10); cp.PaddingBottom=UDim.new(0,12); cp.Parent=tc

    local td = {Button=tb, Content=tc, ActiveBar=ab, Name=name}

    tb.MouseButton1Click:Connect(function()
        if ActiveTab==td then return end
        if ActiveTab then
            Tween(ActiveTab.Button,{BackgroundColor3=Theme.TabInactive},0.2)
            TweenQuick(ActiveTab.Button,{TextColor3=Theme.TextDim})
            ActiveTab.Content.Visible=false; ActiveTab.ActiveBar.Visible=false
        end
        ActiveTab=td
        Tween(tb,{BackgroundColor3=Color3.fromRGB(30,30,48)},0.2)
        TweenQuick(tb,{TextColor3=Theme.Text})
        tc.Visible=true; ab.Visible=true
        tc.Position=UDim2.new(0.05,0,0,0)
        Tween(tc,{Position=UDim2.new(0,0,0,0)},0.2)
    end)
    tb.MouseEnter:Connect(function() if ActiveTab~=td then TweenQuick(tb,{BackgroundColor3=Color3.fromRGB(22,22,35)}) end end)
    tb.MouseLeave:Connect(function() if ActiveTab~=td then TweenQuick(tb,{BackgroundColor3=Theme.TabInactive}) end end)

    TabsData[name]=td
    return tc
end

