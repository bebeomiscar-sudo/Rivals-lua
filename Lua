        Weapons    = Window:AddTab("Weapons"),
        VoidSpam   = Window:AddTab("Void Spam"),
        Katana     = Window:AddTab("Katana"),
        Spoof      = Window:AddTab("Spoof"),
        Teleport   = Window:AddTab("Teleport"),
        Hitbox     = Window:AddTab("Hitbox"),
        UISettings = Window:AddTab("UI Settings"),
    }

    -- =============================================
    --   Safe Require
    -- =============================================

    local function safeRequire(obj)
        local ok, result = pcall(require, obj)
        return ok and result or nil
    end

    -- =============================================
    --   Module References
    -- =============================================

    local FighterController = safeRequire(
        lp.PlayerScripts:WaitForChild("Controllers"):WaitForChild("FighterController")
    )

    RunService.Heartbeat:Wait()

    local MechanicsController = safeRequire(
        lp.PlayerScripts:WaitForChild("Controllers"):WaitForChild("MechanicsController")
    )

    RunService.Heartbeat:Wait()

