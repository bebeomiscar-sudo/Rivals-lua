local function safeFind(parent, ...)
    if not parent then return nil end
    local current = parent
    for _, name in ipairs({...}) do
        if not current then return nil end
        local ok, result = pcall(function()
            return current:FindFirstChild(name)
        end)
        current = ok and result or nil
    end
    return current
end

local function safeWaitFor(parent, name, timeout)
    if not parent then return nil end
    local ok, result = pcall(function()
        return parent:WaitForChild(name, timeout or 5)
    end)
    return ok and result or nil
end

local function worldToScreen(worldPos, cam)
    cam = cam or workspace.CurrentCamera
    if not cam or not worldPos then return nil, false end
    local ok, v, onScreen = pcall(function()
        return cam:WorldToViewportPoint(worldPos)
    end)
    if not ok or not v then return nil, false end
    if not onScreen or v.Z <= 0 then return v, false end
    return Vector2.new(v.X, v.Y), true
end

local function screenCenter(cam)
    cam = cam or workspace.CurrentCamera
    if not cam then return Vector2.zero end
    local vs = cam.ViewportSize
    return Vector2.new(vs.X * 0.5, vs.Y * 0.5)
end

local function getAspectStretch()
    local cam = workspace.CurrentCamera
    if not cam then return 1 end
    local vp = cam.ViewportSize
    if vp.Y == 0 then return 1 end
    return (vp.X / vp.Y) / (16/9)
end

local function getUnstretchedCameraCFrame(cam)
    cam = cam or workspace.CurrentCamera
    if not cam then return CFrame.new() end
    local ok, cf = pcall(function() return cam.CFrame end)
    if not ok then return CFrame.new() end
    if getAspectStretch() == 1 then return cf end
    local pos   = cf.Position
    local right = cf.RightVector
    local look  = cf.LookVector
    local up    = right:Cross(look).Unit
    return CFrame.fromMatrix(pos, right, up, -look)
end

local function screenpos2(worldPos)
    if not worldPos then return nil end
    local sp, onS = worldToScreen(worldPos, Camera)
    if not onS then return nil end
    return Vector2.new(sp.X, sp.Y)
end

local isMobile = UserInputService.TouchEnabled
    and not UserInputService.KeyboardEnabled

local function instanceSafeRequire(obj, timeout)
    if not obj then return nil end
    local ok, result = pcall(require, obj)
    if ok and result then return result end
    local t = tick()
    timeout = timeout or 5
    while tick() - t < timeout do
        ok, result = pcall(require, obj)
        if ok and result then return result end
        task.wait(0.2)
    end
    return nil
end

