local function randVs(minT, maxT)
    local a = math.clamp(tonumber(minT) or 1, 0.1, 2)
    local b = math.clamp(tonumber(maxT) or 1, 0.1, 2)
    if b < a then a, b = b, a end
    if a == b then return a end
    return a + math.random() * (b - a)
end

local function isteammate(targetplayer)
    if not targetplayer then return false end
    return LocalPlayer:GetAttribute("TeamID") == targetplayer:GetAttribute("TeamID")
end

local function valid(char)
    if not char or not char.Parent then return false end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    if not char:FindFirstChild("HumanoidRootPart") then return false end
    local targetplayer = Players:GetPlayerFromCharacter(char)
    if not targetplayer or isteammate(targetplayer) then return false end
    return true
end

local function nearest()
    local cursorpos  = UserInputService:GetMouseLocation()
    local besttarget = nil
    local bestdist   = math.huge
    for _, p in Players:GetPlayers() do
        if p ~= LocalPlayer and p.Character then
            local char = p.Character
            if valid(char) then
                local root = char:FindFirstChild("HumanoidRootPart")
                if root then
                    local screenpos, onscreen = worldToScreen(root.Position, Camera)
                    if onscreen and screenpos then
                        local distance = (Vector2.new(screenpos.X, screenpos.Y) - cursorpos).Magnitude
                        if distance < bestdist then
                            besttarget = char
                            bestdist   = distance
                        end
                    end
                end
            end
        end
    end
    return besttarget
end

local function hitpartfromname(character, partname)
    if not character then return nil end
    if partname == "Closest" then
        local mypos = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not mypos then return character:FindFirstChild("Head") end
        local closest, dist = nil, math.huge
        for _, part in pairs(character:GetChildren()) do
            if part:IsA("BasePart") then
                local d = (part.Position - mypos.Position).Magnitude
                if d < dist then dist = d; closest = part end
            end
        end
        return closest or character:FindFirstChild("Head")
    elseif partname == "Random" then
        local parts = {"Head","HumanoidRootPart","UpperTorso"}
        return character:FindFirstChild(parts[math.random(#parts)]) or character:FindFirstChild("Head")
    else
        return character:FindFirstChild(partname) or character:FindFirstChild("Head")
    end
end

local function predict(targetpart, origin)
    if not rageConfig.prediction.enabled or not targetpart then
        return targetpart and targetpart.Position or Vector3.new()
    end
    local basepos  = targetpart.Position
    local distance = (basepos - origin).Magnitude
    local ping     = 0
    pcall(function()
        ping = Stats.Network.ServerStatsItem["Data Ping"]:GetValue() / 1000
    end)
    local traveltime = distance / 3000
    local totaltime  = (traveltime + ping) * rageConfig.prediction.multiplier
    return basepos + (rageConfig.prediction.velocity * totaltime)
end

local function updatevel()
    if not rageConfig.target.character or not rageConfig.prediction.enabled then
        rageConfig.prediction.velocity  = Vector3.new(0,0,0)
        rageConfig.prediction.lastposition = nil
        return
    end
    local root = rageConfig.target.character:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local now = tick()
    local dt  = now - rageConfig.prediction.lasttime
    if dt > 0 and dt < 0.1 then
        local currentpos = root.Position
        if rageConfig.prediction.lastposition then
            local instantvel = (currentpos - rageConfig.prediction.lastposition) / dt
            rageConfig.prediction.velocity = rageConfig.prediction.velocity:Lerp(instantvel, 0.6)
        end
        rageConfig.prediction.lastposition = currentpos
        rageConfig.prediction.lasttime     = now
    end
end

local function isHidingPhase()
    return rageConfig.voidspam.enabled and rageConfig.voidspam.phase == "hide"
end

local function tickVoidSpam()
    if not rageConfig.voidspam.enabled then return end
    local now     = tick()
    local elapsed = now - rageConfig.voidspam.lastswitch
    local vs      = rageConfig.voidspam
    if vs.phase == "shoot" then
        if elapsed >= vs.currentduration then
            vs.phase           = "hide"
            vs.currentduration = randVs(vs.hide_min, vs.hide_max)
            vs.lastswitch      = now
        end
    elseif vs.phase == "hide" then
        if elapsed >= vs.currentduration then
            vs.phase           = "shoot"
            vs.currentduration = randVs(vs.shoot_min, vs.shoot_max)
            vs.lastswitch      = now
        end
    else
        vs.phase           = "shoot"
        vs.currentduration = randVs(vs.shoot_min, vs.shoot_max)
        vs.lastswitch      = now
    end
end

local function atkCfg()
    if rageConfig.target.attackPosition == "under" then
        return {height=0, front=0, side=0, vertical=-(rageConfig.target.underOffset or 4), radius=0}
    end
    local weapon = getweapon()
    return {height=(weapon and weapon:lower():find("sniper")) and 8 or 2, front=0, side=0, vertical=0, radius=0}
end

local function orbBase(root)
    if not root then return Vector3.zero end
    local s   = atkCfg()
    local pos = root.Position
    local look  = root.CFrame.LookVector
    local right = root.CFrame.RightVector
    return pos + (look*s.front) + (right*s.side) + Vector3.new(0, s.vertical, 0)
end

local function stopsync()
    if not rageConfig.state.csyncactive then return end
    if rageConfig.orbit.connection then
        rageConfig.orbit.connection:Disconnect()
        rageConfig.orbit.connection = nil
    end
    rageConfig.state.csyncactive = false
    rageConfig.orbit.active      = false
    clrVoidSnap()
    rageConfig.voidspam.phase = nil
    if rageConfig.orbit.savedpos and localfighter and localfighter.Entity and localfighter.Entity.RootPart then
        pcall(function()
            localfighter.Entity.RootPart.CFrame = rageConfig.orbit.savedpos
        end)
    end
    rageConfig.orbit.serverpos = nil
    rageConfig.orbit.savedpos  = nil
    oldpos_ragebot = nil
end

local function startsync()
    if rageConfig.state.csyncactive then return end
    if rageConfig.target.immune then return end
    if not rageConfig.target.character or not valid(rageConfig.target.character) then return end
    rageConfig.state.csyncactive = true
    rageConfig.orbit.active      = true
    local s = atkCfg()
    rageConfig.orbit.height = s.height
    rageConfig.orbit.radius = s.radius or 0
    if localfighter and localfighter.Entity and localfighter.Entity.RootPart then
        rageConfig.orbit.savedpos = localfighter.Entity.RootPart.CFrame
    end
    rageConfig.orbit.connection = RunService.Heartbeat:Connect(function(dt)
        if not rageConfig.state.csyncactive then return end
        if rageConfig.target.immune then stopsync() return end
        if not rageConfig.target.character or not valid(rageConfig.target.character) then stopsync() return end
        if not localfighter or not localfighter.Entity or not localfighter.Entity.RootPart then stopsync() return end

        oldpos_ragebot = localfighter.Entity.RootPart.CFrame

        local _weapon = getweapon()
        local checksling = isSling(_weapon)

        if rageConfig.voidspam.enabled and not rageConfig.target.immune then
            tickVoidSpam()
            if rageConfig.voidspam.phase == "hide" then
                local randomX = math.random(-10000, 10000)
                local randomZ = math.random(-10000, 10000)
                rageConfig.orbit.serverpos = Vector3.new(randomX, -99999999999, randomZ)
                pcall(function()
                    localfighter.Entity.RootPart.CFrame = CFrame.new(rageConfig.orbit.serverpos)
                end)
                return
            end
        end

        if not rageConfig.target.character then stopsync() return end
        local root = rageConfig.target.character:FindFirstChild("HumanoidRootPart")
        if not root then stopsync() return end

        if rageConfig.state.outofammo and not checksling and _weapon and not isInfiniteWeapon() then
            local hrp = voidHrp()
            if hrp then
                snapVoid(hrp)
            else
                local randomX = math.random(-10000, 10000)
                local randomZ = math.random(-10000, 10000)
                rageConfig.orbit.serverpos = Vector3.new(randomX, -99999999999, randomZ)
                pcall(function()
                    localfighter.Entity.RootPart.CFrame = CFrame.new(rageConfig.orbit.serverpos)
                end)
            end
            return
        end

        local targetpos = orbBase(root)
        rageConfig.orbit.angle = rageConfig.orbit.angle + (rageConfig.orbit.speed * dt)
        local offset = Vector3.new(
            math.cos(rageConfig.orbit.angle) * rageConfig.orbit.radius,
            rageConfig.orbit.height,
            math.sin(rageConfig.orbit.angle) * rageConfig.orbit.radius
        )
        rageConfig.orbit.serverpos = targetpos + offset

        if not getgenv().InstanceUndergroundEnabled then
            if localfighter and localfighter.Entity and localfighter.Entity.RootPart then
                local currentPos = localfighter.Entity.RootPart.CFrame
                local newPos = CFrame.new(rageConfig.orbit.serverpos)
                local distance = (newPos.Position - currentPos.Position).Magnitude
                if distance < 2000 then
                    localfighter.Entity.RootPart.CFrame = newPos
                    rageConfig.orbit.savedpos = currentPos
                end
            end
        end
    end)
end

local function autoshoot()
    if rageConfig.voidspam.enabled and rageConfig.voidspam.phase == "hide" then return end
    if not rageConfig.target.enabled or not rageConfig.target.character or not rageConfig.target.autoshoot then return end
    if rageConfig.target.immune then return end
    local lf = Modules.fighter and Modules.fighter.LocalFighter
    if not lf or not lf.EquippedItem then return end
    if not isInfiniteWeapon() then
        if rageConfig.state.reloading or rageConfig.state.outofammo then return end
    end
    local targetChar = rageConfig.target.character
    if not valid(targetChar) then return end
    local hitPart = hitpartfromname(targetChar, rageConfig.target.hitpart)
    if not hitPart then return end
    local shootPos
    if rageConfig.state.csyncactive and rageConfig.orbit.serverpos then
        shootPos = rageConfig.orbit.serverpos
    else
        local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        shootPos = root and root.Position or Vector3.new()
    end
    local targetPos = predict(hitPart, shootPos)
    if not Modules.utility or not Modules.enums then return end
    local data = {
        [utf8.char(1)] = {
            [utf8.char(0)] = Modules.utility:EncodeCFrame(CFrame.new(shootPos, targetPos)),
            [utf8.char(1)] = Modules.utility:EncodeCFrame(CFrame.new(shootPos, targetPos)),
            [utf8.char(2)] = hitPart,
            [utf8.char(3)] = Modules.utility:EncodeCFrame(CFrame.new(0.43, 0.25, 0.42)),
        },
    }
    local equipped = lf.EquippedItem
    if equipped and equipped:Get("ObjectID") then
        local attempts = math.clamp(math.floor(tonumber(rageConfig.target.shootAttempts) or 1), 1, 3)
        for _ = 1, attempts do
            pcall(function()
                ReplicatedStorage.Remotes.Replication.Fighter.UseItem:FireServer(
                    equipped:Get("ObjectID"),
                    Modules.enums:ToEnum("StartShooting"),
                    data,
                    nil
                )
            end)
        end
    end
end

local function cleartarget()
    rageConfig.target.enabled   = false
    stopsync()
    rageConfig.target.character  = nil
    rageConfig.target.lastchar   = nil
    rageConfig.target.lastplayer = nil
    rageConfig.target.manualkey  = false
    rageConfig.target.immune     = false
end

local function settarget(char)
    if not char then return end
    rageConfig.target.enabled    = true
    rageConfig.target.character  = char
    rageConfig.target.lastchar   = char
    rageConfig.target.lastplayer = Players:GetPlayerFromCharacter(char)
