-- =============================================
--   Timer Logic — 3 seconds
--   Smooth countdown, no freeze
--   Steps are small (heartbeat-safe)
-- =============================================

local TIMER_DURATION    = 3    -- seconds
local timerDone         = false
local selectedScript    = nil

-- Timer runs via heartbeat for smooth animation
-- without hammering the main thread
task.spawn(function()
    safeWait(0.6) -- wait for card to appear first

    local startTime = tick()
    local lastSecond = TIMER_DURATION

    -- Animate timer bar
    TweenService:Create(TimerFill, TweenInfo.new(
        TIMER_DURATION,
        Enum.EasingStyle.Linear,
        Enum.EasingDirection.In
    ), {
        Size = UDim2.new(0, 0, 1, 0)
    }):Play()

    -- Update label every 0.05s (smooth but not spammy)
    while not timerDone do
        local elapsed  = tick() - startTime
        local remaining = math.max(0, TIMER_DURATION - elapsed)
        local secs      = math.ceil(remaining)

        if secs ~= lastSecond then
            lastSecond = secs
        end

        TimerLabel.Text = ("Loading... %.1fs"):format(remaining)

        if elapsed >= TIMER_DURATION then
            timerDone = true
            TimerLabel.Text = "Loading..."
            break
        end

        -- Wait 0.05s via heartbeat — not task.wait (safer)
        local waitStart = tick()
        repeat
            RunService.Heartbeat:Wait()
        until tick() - waitStart >= 0.05
    end
end)

-- =============================================
--   Selection Handler
--   Triggers on button click OR timer end
-- =============================================

local function onScriptSelected(scriptName)
    if selectedScript then return end  -- prevent double fire
    selectedScript = scriptName
    timerDone = true

    -- Flash selected button
    local flashColor = scriptName == "Rivals"
        and Color3.fromRGB(100, 80, 255)
        or  Color3.fromRGB(255, 80, 130)

    -- Status label update
    SubLabel.Text = "Loading " .. scriptName .. "..."
    TweenService:Create(SubLabel, TweenInfo.new(0.3), {
        TextColor3 = flashColor
    }):Play()

    TimerLabel.Text = "Selected: " .. scriptName

    -- Small delay so animation feels smooth
    -- then fade out entire UI
    task.spawn(function()
        safeWait(0.3)

        -- Fade out UI elements first (staggered)
        TweenService:Create(TitleLabel, TweenInfo.new(0.25), {
            TextTransparency = 1
        }):Play()
        safeWait(0.05)
        TweenService:Create(SubLabel, TweenInfo.new(0.25), {
            TextTransparency = 1
        }):Play()
        TweenService:Create(TimerLabel, TweenInfo.new(0.25), {
            TextTransparency = 1
        }):Play()
        safeWait(0.15)

        -- Fade card out
        TweenService:Create(Card, TweenInfo.new(0.35, Enum.EasingStyle.Sine), {
            BackgroundTransparency = 1,
            Position = UDim2.new(0.5, -220, 0.5, -190)
        }):Play()
        TweenService:Create(BG, TweenInfo.new(0.35, Enum.EasingStyle.Sine), {
            BackgroundTransparency = 1
        }):Play()

        -- Fade blur out
        for i = 24, 0, -3 do
            blur.Size = i
            safeWait(0.03)
        end

        safeWait(0.2)

        -- Destroy selector UI cleanly
        SelectorGui:Destroy()
        blur:Destroy()

        -- Small gap before loading chosen script
        safeWait(0.1)

        -- =============================================
        --   Load Chosen Script
        -- =============================================

        if scriptName == "Rivals" then
            loadRivalsScript()
        elseif scriptName == "VoidSpam" then
            loadVoidSpamScript()
        end
    end)
end

