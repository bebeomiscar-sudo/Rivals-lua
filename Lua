local antiAimSettings = {
    enabled     = false,
    yawtype     = "none",
    pitchtype   = "none",
    angletype   = "none",
    customangle = 0,
    minspeed    = 10,
    maxspeed    = 20,
    minangle    = 30,
    maxangle    = 60,
    randomangle = false,
}

local antiAimState = {
    smoothyaw    = 0,
    smoothpitch  = 0,
    smoothroll   = 0,
    framecounter = 0,
}

local underground_enabled = false
