local function CreateDropdown(parent, labelText, configKey, options, callback, layoutOrder)
    local currentVal = Config[configKey] or options[1]
    local isOpen     = false

    local Frame = Instance.new("Frame")
    Frame.Size             = UDim2.new(1,-20,0,42)
    Frame.BackgroundColor3 = Theme.Secondary
    Frame.BorderSizePixel  = 0
    Frame.LayoutOrder      = layoutOrder or 0
    Frame.ClipsDescendants = false
    Frame.ZIndex           = 20
    Frame.Parent           = parent
    Instance.new("UICorner", Frame).CornerRadius = UDim.new(0,10)

    local Label = Instance.new("TextLabel")
    Label.Size               = UDim2.new(0.5,0,1,0)
    Label.Position           = UDim2.new(0,14,0,0)
    Label.BackgroundTransparency = 1
    Label.Text               = labelText
    Label.TextColor3         = Theme.Text
    Label.TextSize           = 13
    Label.Font               = Enum.Font.Gotham
    Label.TextXAlignment     = Enum.TextXAlignment.Left
    Label.ZIndex             = 21
    Label.Parent             = Frame

    local ValueBtn = Instance.new("TextButton")
    ValueBtn.Size             = UDim2.new(0.48,-10,0,30)
    ValueBtn.Position         = UDim2.new(0.52,0,0.5,-15)
    ValueBtn.BackgroundColor3 = Theme.AccentDark
    ValueBtn.BorderSizePixel  = 0
    ValueBtn.Text             = currentVal .. " ▾"
    ValueBtn.TextColor3       = Theme.Text
    ValueBtn.TextSize         = 12
    ValueBtn.Font             = Enum.Font.GothamBold
    ValueBtn.ZIndex           = 21
    ValueBtn.Parent           = Frame
    Instance.new("UICorner", ValueBtn).CornerRadius = UDim.new(0,8)

    local DropFrame = Instance.new("Frame")
    DropFrame.Size             = UDim2.new(0.48,-10,0,#options*32+6)
    DropFrame.Position         = UDim2.new(0.52,0,1,4)
    DropFrame.BackgroundColor3 = Theme.Secondary
    DropFrame.BorderSizePixel  = 0
    DropFrame.ZIndex           = 50
    DropFrame.Visible          = false
    DropFrame.Parent           = Frame
    Instance.new("UICorner", DropFrame).CornerRadius = UDim.new(0,8)

    local DStroke = Instance.new("UIStroke")
    DStroke.Color = Theme.Border
    DStroke.Thickness = 1
    DStroke.Parent = DropFrame

    local DList = Instance.new("UIListLayout")
    DList.SortOrder = Enum.SortOrder.LayoutOrder
    DList.Padding   = UDim.new(0,2)
    DList.Parent    = DropFrame

    local DPad = Instance.new("UIPadding")
    DPad.PaddingTop    = UDim.new(0,3)
    DPad.PaddingBottom = UDim.new(0,3)
    DPad.PaddingLeft   = UDim.new(0,3)
    DPad.PaddingRight  = UDim.new(0,3)
    DPad.Parent = DropFrame

    for i, option in ipairs(options) do
        local OptBtn = Instance.new("TextButton")
        OptBtn.Size             = UDim2.new(1,0,0,28)
        OptBtn.BackgroundColor3 = option == currentVal and Theme.Accent or Color3.fromRGB(25,25,40)
        OptBtn.BorderSizePixel  = 0
        OptBtn.Text             = option
        OptBtn.TextColor3       = Theme.Text
        OptBtn.TextSize         = 12
        OptBtn.Font             = Enum.Font.Gotham
        OptBtn.LayoutOrder      = i
        OptBtn.ZIndex           = 51
        OptBtn.Parent           = DropFrame
        Instance.new("UICorner", OptBtn).CornerRadius = UDim.new(0,6)

        OptBtn.MouseButton1Click:Connect(function()
            currentVal        = option
            Config[configKey] = option
            ValueBtn.Text     = option .. " ▾"
            DropFrame.Visible = false
            isOpen            = false
            for _, child in ipairs(DropFrame:GetChildren()) do
                if child:IsA("TextButton") then
                    TweenQuick(child, {BackgroundColor3 = child.Text == option and Theme.Accent or Color3.fromRGB(25,25,40)})
                end
            end
            if callback then callback(option) end
        end)

        OptBtn.MouseEnter:Connect(function()
            if OptBtn.Text ~= currentVal then
                TweenQuick(OptBtn, {BackgroundColor3=Color3.fromRGB(35,35,55)})
            end
        end)
        OptBtn.MouseLeave:Connect(function()
            if OptBtn.Text ~= currentVal then
                TweenQuick(OptBtn, {BackgroundColor3=Color3.fromRGB(25,25,40)})
            end
        end)
    end

    ValueBtn.MouseButton1Click:Connect(function()
        isOpen = not isOpen
        DropFrame.Visible = isOpen
        Tween(ValueBtn, {BackgroundColor3 = isOpen and Theme.Accent or Theme.AccentDark}, 0.15)
    end)

    return Frame
end

