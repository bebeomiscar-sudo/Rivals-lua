        Values     = getPlayerList(),
        Default    = 1,
        Multi      = false,
        Searchable = true,
        Callback   = function(val) tpConfig.autoTarget = val end,
    })

    TpLeft:AddButton({
        Text = "Refresh Player List",
        Func = function()
            Options.TpTargetPlayer:SetValues(getPlayerList())
            Library:Notify("Player list refreshed!", 2)
        end,
    })

    TpLeft:AddButton({
        Text = "Teleport Now",
        Func = function()
            local targetName = Options.TpTargetPlayer.Value
            if not targetName or targetName == "" then
                Library:Notify("Select a player first!", 2) return
            end
            local target = Players:FindFirstChild(targetName)
            if not target then Library:Notify("Player not found!", 2) return end
            teleportToPlayer(target)
        end,
    })

    TpLeft:AddToggle("StayOnTop", {
        Text     = "Stay On Top Of Player",
        Default  = true,
        Callback = function(val)
            tpConfig.stayOnTop = val
            if not val then stopStayOnTop() end
        end,
    })

    TpLeft:AddButton({
        Text = "Stop Staying On Top",
        Func = function()
            stopStayOnTop()
            Library:Notify("Stopped staying on top!", 2)
        end,
    })

    TpLeft:AddDivider()

    TpLeft:AddToggle("AutoTP", {
        Text     = "Auto Teleport Loop",
        Default  = false,
        Callback = function(val)
            tpConfig.autoTP = val
            if val then
                autoTPThread = task.spawn(function()
                    while tpConfig.autoTP do
                        local targetName = Options.TpTargetPlayer.Value
                        if targetName and targetName ~= "" then
                            local target = Players:FindFirstChild(targetName)
                            if target then teleportToPlayer(target) end
                        end
                        task.wait(tpConfig.autoDelay)
                    end
                end)
            else
                if autoTPThread then pcall(task.cancel, autoTPThread) autoTPThread = nil end
                stopStayOnTop()
            end
        end,
    })

    TpRight:AddSlider("AutoTPDelay", {
        Text     = "Auto TP Delay",
        Default  = 10,
        Min      = 1,
        Max      = 50,
        Rounding = 0,
        Suffix   = "x0.1s",
        Callback = function(val) tpConfig.autoDelay = val * 0.1 end,
    })

    TpRight:AddToggle("VisibleCheck", {
        Text     = "In-Game Check",
        Default  = true,
        Callback = function(val) tpConfig.onlyInGame = val end,
    })

    -- ============================================================
    --   TAB 6 — HITBOX
    -- ============================================================

    local HitboxLeft  = Tabs.Hitbox:AddLeftGroupbox("Hitbox Expander")
    local HitboxRight = Tabs.Hitbox:AddRightGroupbox("Settings")

    local hitboxConfig = {
        enabled      = false,
        size         = 10,
        part         = "HitboxHead",
        transparency = 0.8,
        showESP      = true,
    }

    local originalSizes = {}
    local hitboxConn    = nil

    local function getHitboxPart(player)
        local char = workspace:FindFirstChild(player.Name)
        if not char then return nil end
        local hitbox = char:FindFirstChild(hitboxConfig.part)
        if not hitbox or not hitbox:IsA("BasePart") then return nil end
        return hitbox
    end

    local function storeOriginalSize(player, hitbox)
        if originalSizes[player.Name] then return end
        originalSizes[player.Name] = hitbox.Size
    end

    local function expandHitbox(player)
        if player == lp then return end
        local hitbox = getHitboxPart(player)
        if not hitbox then return end
        storeOriginalSize(player, hitbox)
        local newSize = Vector3.new(hitboxConfig.size, hitboxConfig.size, hitboxConfig.size)
        pcall(function()
            hitbox.Size = newSize
            if hitboxConfig.showESP then
                hitbox.Transparency = hitboxConfig.transparency
                hitbox.Color        = Color3.fromRGB(255, 50, 50)
                hitbox.Material     = Enum.Material.Neon
                hitbox.CanCollide   = false
            else
                hitbox.Transparency = 1
            end
        end)
    end

    local function restoreHitbox(player)
        local hitbox   = getHitboxPart(player)
        local original = originalSizes[player.Name]
        if not hitbox or not original then return end
        pcall(function()
            hitbox.Size         = original
            hitbox.Transparency = 1
            hitbox.Material     = Enum.Material.SmoothPlastic
            hitbox.Color        = Color3.fromRGB(255, 255, 255)
        end)
        originalSizes[player.Name] = nil
    end

    local function expandAll()
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= lp then pcall(function() expandHitbox(player) end) end
        end
    end

    local function restoreAll()
        for _, player in pairs(Players:GetPlayers()) do
            pcall(function() restoreHitbox(player) end)
        end
        originalSizes = {}
    end

    HitboxLeft:AddToggle("HitboxEnabled", {
        Text     = "Enable Hitbox Expander",
        Default  = false,
        Risky    = true,
        Callback = function(val)
            hitboxConfig.enabled = val
            if val then
                expandAll()
                hitboxConn = RunService.Heartbeat:Connect(function()
                    for _, player in pairs(Players:GetPlayers()) do
                        if player ~= lp then
                            pcall(function()
                                local hitbox = getHitboxPart(player)
                                if hitbox then
                                    local ts = Vector3.new(
                                        hitboxConfig.size, hitboxConfig.size, hitboxConfig.size
                                    )
                                    if hitbox.Size ~= ts then expandHitbox(player) end
                                end
                            end)
                        end
                    end
                end)
                Library:Notify("Hitbox Expander Active! Size: " .. hitboxConfig.size, 3)
            else
                restoreAll()
                if hitboxConn then hitboxConn:Disconnect() hitboxConn = nil end
                Library:Notify("Hitbox restored", 2)
            end
        end,
    })

    HitboxLeft:AddButton({
        Text = "Expand All Now",
        Func = function() expandAll() Library:Notify("All hitboxes expanded!", 2) end,
    })

    HitboxLeft:AddButton({
        Text = "Restore All Now",
        Func = function() restoreAll() Library:Notify("All hitboxes restored!", 2) end,
    })

    HitboxRight:AddSlider("HitboxSize", {
        Text     = "Hitbox Size",
        Default  = 10,
        Min      = 1,
        Max      = 60,
        Rounding = 0,
        Suffix   = " studs",
        Callback = function(val)
            hitboxConfig.size = val
            if hitboxConfig.enabled then expandAll() end
        end,
    })

    HitboxRight:AddToggle("HitboxVisual", {
        Text     = "Show Hitbox Visual",
        Default  = true,
        Callback = function(val)
            hitboxConfig.showESP = val
            if hitboxConfig.enabled then expandAll() end
        end,
    })

    HitboxRight:AddSlider("HitboxTransparency", {
        Text     = "Hitbox Transparency",
        Default  = 8,
        Min      = 0,
        Max      = 10,
        Rounding = 0,
        Suffix   = "x0.1",
        Callback = function(val)
            hitboxConfig.transparency = val * 0.1
            if hitboxConfig.enabled then expandAll() end
        end,
    })

    HitboxRight:AddDropdown("HitboxPartName", {
        Text     = "Hitbox Part Target",
        Values   = { "HitboxHead", "HitboxBody", "HitboxLegs" },
        Default  = 1,
        Callback = function(val)
            if hitboxConfig.enabled then restoreAll() end
            hitboxConfig.part = val
            if hitboxConfig.enabled then expandAll() end
        end,
    })

    for _, player in pairs(Players:GetPlayers()) do
        if player ~= lp then
            player.CharacterAdded:Connect(function()
                if hitboxConfig.enabled then
                    task.wait(0.5)
                    pcall(function()
                        originalSizes[player.Name] = nil
                        expandHitbox(player)
                    end)
                end
            end)
        end
    end

    Players.PlayerAdded:Connect(function(player)
        player.CharacterAdded:Connect(function()
            if hitboxConfig.enabled and player ~= lp then
                task.wait(0.5)
                pcall(function() expandHitbox(player) end)
            end
        end)
    end)

    -- ============================================================
    --   TAB 7 — UI SETTINGS
    -- ============================================================

    local MenuGroup = Tabs.UISettings:AddLeftGroupbox("Menu")

    MenuGroup:AddToggle("KeybindMenuOpen", {
        Default  = Library.KeybindFrame.Visible,
        Text     = "Open Keybind Menu",
        Callback = function(val)
            Library.KeybindFrame.Visible = val
        end,
    })

    MenuGroup:AddToggle("ShowCustomCursor", {
        Text     = "Custom Cursor",
        Default  = true,
        Callback = function(val) Library.ShowCustomCursor = val end,
    })

    MenuGroup:AddDivider()

    MenuGroup:AddLabel("Menu Keybind"):AddKeyPicker("MenuKeybind", {
        Default = "RightShift",
        NoUI    = true,
        Text    = "Menu Keybind",
    })

    MenuGroup:AddButton({
        Text = "Unload",
        Func = function()
            stopVoidSpam()
            stopVelSpike()
            stopAntiAim()
            stopStayOnTop()
            restoreAll()
            cleanTripESP()

            if noCooldownConn      then noCooldownConn:Disconnect()      end
            if instantReloadConn   then instantReloadConn:Disconnect()   end
            if infiniteAmmoConn    then infiniteAmmoConn:Disconnect()    end
            if rapidBurstConn      then rapidBurstConn:Disconnect()      end
            if instantChargeConn   then instantChargeConn:Disconnect()   end
            if infiniteDaggersConn then infiniteDaggersConn:Disconnect() end
            if rapidDaggerConn     then rapidDaggerConn:Disconnect()     end
            if spoofLevelConn      then spoofLevelConn:Disconnect()      end
            if tripDetectConn      then tripDetectConn:Disconnect()      end
            if hitboxConn          then hitboxConn:Disconnect()          end
            if katanaLoopThread    then pcall(task.cancel, katanaLoopThread) end

            Library:Unload()
        end,
    })

    Library.ToggleKeybind = Options.MenuKeybind

    -- ============================================================
    --   Watermark
    -- ============================================================

    Library:SetWatermarkVisibility(true)

    local frameTimer = tick()
    local frameCount = 0
    local currentFPS = 60

    local function getPing()
        local ok, val = pcall(function()
            return math.floor(
                game:GetService("Stats")
                    .Network.ServerStatsItem["Data Ping"]:GetValue()
            )
        end)
        return ok and val or 0
    end

    RunService.RenderStepped:Connect(function()
        frameCount += 1
        if tick() - frameTimer >= 1 then
            currentFPS = frameCount
            frameTimer = tick()
            frameCount = 0
        end
        Library:SetWatermark(
            ("Rivals Hub | %d fps | %d ms"):format(currentFPS, getPing())
        )
    end)

    Library:OnUnload(function()
        Library.Unloaded = true
    end)

    -- ============================================================
    --   Save / Theme
    -- ============================================================

    ThemeManager:SetLibrary(Library)
    SaveManager:SetLibrary(Library)

    SaveManager:IgnoreThemeSettings()
    SaveManager:SetIgnoreIndexes({ "MenuKeybind" })

    ThemeManager:SetFolder("RivalsHub")
    SaveManager:SetFolder("RivalsHub/Rivals")

    SaveManager:BuildConfigSection(Tabs.UISettings)
    ThemeManager:ApplyToTab(Tabs.UISettings)

    SaveManager:LoadAutoloadConfig()

    Library:Notify("Rivals Hub Loaded! RightShift to toggle menu.", 5)

end -- end loadRivalsScript

-- =============================================
--   VOIDSPAM ONLY SCRIPT LOADER
--   Standalone — no Linoria, clean UI
--   Uses same crash prevention approach
-- =============================================

function loadVoidSpamScript()

    local repo = "https://raw.githubusercontent.com/xyznick/UELinoriaLib/main/"

    local Library, ThemeManager, SaveManager

    local ok1, lib = pcall(function()
        return loadstring(game:HttpGet(repo .. "Library.lua"))()
    end)
    if not ok1 then warn("Library load failed") return end
    Library = lib

    RunService.Heartbeat:Wait()

    local ok2, tm = pcall(function()
        return loadstring(game:HttpGet(repo .. "addons/ThemeManager.lua"))()
    end)
    if not ok2 then warn("ThemeManager load failed") return end
    ThemeManager = tm

    RunService.Heartbeat:Wait()

    local ok3, sm = pcall(function()
        return loadstring(game:HttpGet(repo .. "addons/SaveManager.lua"))()
    end)
    if not ok3 then warn("SaveManager load failed") return end
    SaveManager = sm

    RunService.Heartbeat:Wait()

    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local Options = getgenv().Options
    local Toggles = getgenv().Toggles

    Library.ShowCustomCursor = true
    Library.NotifySide       = "Left"

    -- =============================================
    --   Window
    -- =============================================

    local Window = Library:CreateWindow({
        Title            = "Void Spam Hub",
        Center           = true,
        AutoShow         = true,
        Resizable        = true,
        ShowCustomCursor = true,
        TabPadding       = 8,
        MenuFadeTime     = 0.2,
    })

    local Tabs = {
        VoidSpam   = Window:AddTab("Void Spam"),
        UISettings = Window:AddTab("UI Settings"),
    }

    local function safeRequire(obj)
        local ok, result = pcall(require, obj)
        return ok and result or nil
    end

    -- =============================================
    --   Void Core (same logic, crash-safe)
    -- =============================================

    local VoidLeft  = Tabs.VoidSpam:AddLeftGroupbox("Void Spam")
    local VoidRight = Tabs.VoidSpam:AddRightGroupbox("Settings")

    local voidHRPRef     = nil
    local savedClientC   = nil
    local savedClientV   = nil
    local savedClientVA  = nil
    local lockedCameraC  = nil
    local voidHBConn     = nil
    local velSpikeConn   = nil
    local antiAimConn    = nil
    local antiAimLocked  = nil

    local VOID_X_MAX = 450000
    local VOID_Y_MAX = 590000
    local VOID_Z_MAX = 230000
    local VoidIntensity = 1.0

    local function betterRandom(mi, ma, dmi, dma)
        local val = math.random(mi, ma)
        local attempts = 0
        repeat
            val = math.random(mi, ma)
            attempts += 1
        until val < dmi or val > dma or attempts > 20
        return val
    end

    local function getVoidPos()
        local xi = math.floor(VOID_X_MAX * VoidIntensity)
        local yi = math.floor(VOID_Y_MAX * VoidIntensity)
        local zi = math.floor(VOID_Z_MAX * VoidIntensity)
        local xe = math.floor(xi * 0.5)
        local ye = math.floor(yi * 0.5)
        local ze = math.floor(zi * 0.5)
        return Vector3.new(
            betterRandom(-xi, xi, -xe, xe),
            betterRandom(0,   yi,  0,  ye),
            betterRandom(-zi, zi, -ze, ze)
        )
    end

    local function getVoidVel()
        local xi = math.floor(VOID_X_MAX * VoidIntensity)
        local yi = math.floor(VOID_Y_MAX * VoidIntensity)
        local zi = math.floor(VOID_Z_MAX * VoidIntensity)
        return Vector3.new(
            math.random(-xi, xi),
            math.random(-yi, yi),
            math.random(-zi, zi)
        )
    end

    local function lockCamera()
        lockedCameraC = workspace.CurrentCamera.CFrame
    end

    local function applyCameraLock()
        if lockedCameraC then
            workspace.CurrentCamera.CFrame = lockedCameraC
        end
    end

    local function startVoidSpam()
        if voidHBConn then voidHBConn:Disconnect() voidHBConn = nil end
        lockCamera()
        voidHBConn = RunService.Heartbeat:Connect(function()
            pcall(function()
                local char = lp.Character
                if not char then return end
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if not hrp then return end
                voidHRPRef   = hrp
                savedClientC  = hrp.CFrame
                savedClientV  = hrp.AssemblyLinearVelocity
                savedClientVA = hrp.AssemblyAngularVelocity
                local vPos = getVoidPos()
                hrp.CFrame = CFrame.new(vPos)
                    * CFrame.Angles(math.pi, math.pi, math.pi)
                hrp.AssemblyLinearVelocity  = getVoidVel()
                hrp.AssemblyAngularVelocity = getVoidVel()
            end)
        end)
        RunService:BindToRenderStep(
            "VoidSyncStandalone",
            Enum.RenderPriority.First.Value,
            function()
                if voidHRPRef and savedClientC then
                    pcall(function()
                        voidHRPRef.CFrame = savedClientC
                        voidHRPRef.AssemblyLinearVelocity  = savedClientV
                        voidHRPRef.AssemblyAngularVelocity = savedClientVA
                    end)
                end
                applyCameraLock()
            end
        )
    end

    local function stopVoidSpam()
        if voidHBConn then voidHBConn:Disconnect() voidHBConn = nil end
        pcall(function() RunService:UnbindFromRenderStep("VoidSyncStandalone") end)
        voidHRPRef    = nil
        lockedCameraC = nil
    end

    local velSpikeRate = 0.05
    local lastSpike    = 0

    local function startVelSpike()
        if velSpikeConn then velSpikeConn:Disconnect() velSpikeConn = nil end
        velSpikeConn = RunService.Heartbeat:Connect(function()
            if tick() - lastSpike < velSpikeRate then return end
            lastSpike = tick()
            pcall(function()
                local char = lp.Character
                if not char then return end
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if not hrp then return end
                hrp.AssemblyLinearVelocity = getVoidVel()
            end)
        end)
    end

    local function stopVelSpike()
        if velSpikeConn then velSpikeConn:Disconnect() velSpikeConn = nil end
    end

    local UpdateCamRemote = ReplicatedStorage
        :WaitForChild("Remotes")
        :WaitForChild("Replication")
        :WaitForChild("Fighter")
        :FindFirstChild("UpdateCameraRotation")

    local Utility = safeRequire(
        ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Utility")
    )

    local function startAntiAim()
        antiAimLocked = Vector2.new(
            math.random() * math.pi * 2,
            math.random() * math.pi * 2
        )
        antiAimConn = RunService.Heartbeat:Connect(function()
            if not UpdateCamRemote then return end
            if not Utility then return end
            pcall(function()
                local encoded = Utility:EncodeCameraRotation(antiAimLocked)
                UpdateCamRemote:FireServer(encoded, nil)
            end)
        end)
    end

    local function stopAntiAim()
        if antiAimConn then antiAimConn:Disconnect() antiAimConn = nil end
        antiAimLocked = nil
    end

    -- =============================================
    --   UI Toggles
    -- =============================================

    VoidLeft:AddToggle("VoidSpam", {
        Text     = "Standard Void Spam",
        Default  = false,
        Tooltip  = "TPs to void every frame then syncs back",
        Callback = function(val)
            if val then startVoidSpam() Library:Notify("Void Spam Active!", 3)
            else stopVoidSpam() Library:Notify("Void Spam Off", 2) end
        end,
    })

    VoidLeft:AddToggle("VelocitySpike", {
        Text     = "Velocity Spike",
        Default  = false,
        Tooltip  = "Randomly spikes velocity every frame",
        Callback = function(val)
            if val then startVelSpike() else stopVelSpike() end
        end,
    })

    VoidLeft:AddDivider()

    VoidLeft:AddToggle("MetaVoidSpam", {
        Text     = "Meta Void Spam",
        Default  = false,
        Risky    = true,
        Tooltip  = "Void + Velocity Spike combined — meta combo",
        Callback = function(val)
            Toggles.VoidSpam:SetValue(val)
            Toggles.VelocitySpike:SetValue(val)
            if val then Library:Notify("Meta Void Spam Active!", 3)
            else Library:Notify("Meta Void Spam Off", 2) end
        end,
    })

    VoidLeft:AddDivider()

    VoidLeft:AddToggle("AntiAim", {
        Text     = "Anti Aim",
        Default  = false,
        Risky    = true,
        Tooltip  = "Sends fake camera rotation to server",
        Callback = function(val)
            if val then startAntiAim() Library:Notify("Anti Aim Active!", 3)
            else stopAntiAim() Library:Notify("Anti Aim Off", 2) end
        end,
    })

    VoidLeft:AddButton({
        Text = "Stop All",
        Func = function()
            Toggles.VoidSpam:SetValue(false)
            Toggles.VelocitySpike:SetValue(false)
            Toggles.MetaVoidSpam:SetValue(false)
            Toggles.AntiAim:SetValue(false)
            Library:Notify("All features stopped!", 2)
        end,
    })

    VoidRight:AddSlider("VoidIntensitySlider", {
        Text     = "Void Intensity",
        Default  = 100,
        Min      = 1,
        Max      = 100,
        Rounding = 0,
        Suffix   = "%",
        Callback = function(val) VoidIntensity = val / 100 end,
    })

    VoidRight:AddSlider("VelSpikeRateSlider", {
        Text     = "Spike Rate",
        Default  = 5,
        Min      = 1,
        Max      = 20,
        Rounding = 0,
        Suffix   = "x",
        Callback = function(val) velSpikeRate = 0.1 / val end,
    })

    VoidRight:AddLabel(
        "Void Ranges:\nY: 0-590,000\nX: 0-450,000\nZ: 0-230,000\n\n"..
        "Camera locks to where\nyou look when you\nenable void spam.",
        true
    )

    -- =============================================
    --   UI Settings Tab
    -- =============================================

    local MenuGroup = Tabs.UISettings:AddLeftGroupbox("Menu")

    MenuGroup:AddToggle("ShowCustomCursor", {
        Text     = "Custom Cursor",
        Default  = true,
        Callback = function(val) Library.ShowCustomCursor = val end,
    })

    MenuGroup:AddLabel("Menu Keybind"):AddKeyPicker("MenuKeybind", {
        Default = "RightShift",
        NoUI    = true,
        Text    = "Menu Keybind",
    })

    MenuGroup:AddButton({
        Text = "Unload",
        Func = function()
            stopVoidSpam()
            stopVelSpike()
            stopAntiAim()
            Library:Unload()
        end,
    })

    Library.ToggleKeybind = Options.MenuKeybind

    -- =============================================
    --   Watermark
    -- =============================================

    Library:SetWatermarkVisibility(true)

    local frameTimer = tick()
    local frameCount = 0
    local currentFPS = 60

    local function getPing()
        local ok, val = pcall(function()
            return math.floor(
                game:GetService("Stats")
                    .Network.ServerStatsItem["Data Ping"]:GetValue()
            )
        end)
        return ok and val or 0
    end

    RunService.RenderStepped:Connect(function()
        frameCount += 1
        if tick() - frameTimer >= 1 then
            currentFPS = frameCount
            frameTimer = tick()
            frameCount = 0
        end
        Library:SetWatermark(
            ("Void Hub | %d fps | %d ms"):format(currentFPS, getPing())
        )
    end)

    Library:OnUnload(function()
        Library.Unloaded = true
    end)

    ThemeManager:SetLibrary(Library)
    SaveManager:SetLibrary(Library)

    SaveManager:IgnoreThemeSettings()
    SaveManager:SetIgnoreIndexes({ "MenuKeybind" })

    ThemeManager:SetFolder("RivalsHub")
    SaveManager:SetFolder("RivalsHub/VoidSpam")

    SaveManager:BuildConfigSection(Tabs.UISettings)
    ThemeManager:ApplyToTab(Tabs.UISettings)

    SaveManager:LoadAutoloadConfig()

    Library:Notify("Void Spam Hub Loaded! RightShift to toggle.", 5)

end -- end loadVoidSpamScript
