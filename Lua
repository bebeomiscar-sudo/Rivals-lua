-- =============================================
--   Timer Logic — 3 seconds
-- =============================================

local TIMER_DURATION = 3
local timerDone      = false
local selectedScript = nil

task.spawn(function()
    safeWait(0.6)

    TweenService:Create(TimerFill, TweenInfo.new(
        TIMER_DURATION,
        Enum.EasingStyle.Linear,
        Enum.EasingDirection.In
    ), {
        Size = UDim2.new(0, 0, 1, 0)
    }):Play()

    while not timerDone do
        local elapsed   = tick() - (tick() - TIMER_DURATION + TIMER_DURATION)
        local remaining = math.max(0, TIMER_DURATION - elapsed)
        TimerLabel.Text = ("Loading... %.1fs"):format(remaining)

        if elapsed >= TIMER_DURATION then
            timerDone = true
            TimerLabel.Text = "Select a script above ↑"
            break
        end

        local w = tick()
        repeat RunService.Heartbeat:Wait() until tick() - w >= 0.05
    end
end)

-- Proper timer using tick reference
