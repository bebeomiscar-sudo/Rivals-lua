local function rndRange(a, b)
    return a + math.random()*(b-a)
end

local headMotors    = {}
local headMotorsC0  = {}

local function updateHeadMotors()
    pcall(function()
        headMotors   = {}
        headMotorsC0 = {}
        local char = LocalPlayer.Character
        if not char then return end
        for _, v in pairs(char:GetDescendants()) do
            if v:IsA("Motor6D") then
                headMotors[v.Name] = v
                headMotorsC0[v]    = v.C0
            end
        end
    end)
end

local function resetHeadMotors()
    pcall(function()
        for m, c0 in pairs(headMotorsC0) do
            if m and m.Parent then m.C0 = c0 end
        end
    end)
end

local function calcYaw()
    local t, s = antiAimSettings, antiAimState
    local yaw = 0
    pcall(function()
        if t.yawtype == "jitter" then
            local a = math.rad(t.randomangle and rndRange(t.minangle,t.maxangle) or t.minangle)
            yaw = math.random()>0.5 and a or -a
        elseif t.yawtype == "spinbot" then
            yaw = (tick()*rndRange(t.minspeed/10,t.maxspeed/10)) % (2*math.pi)
        elseif t.yawtype == "random" then
            yaw = s.framecounter%30==0 and rndRange(-math.rad(t.maxangle),math.rad(t.maxangle)) or s.smoothyaw
        end
    end)
    return yaw
end

local function calcPitch()
    local t, s = antiAimSettings, antiAimState
    local pitch = 0
    pcall(function()
        if t.pitchtype == "jitter" then
            local a = math.rad(t.randomangle and rndRange(t.minangle,t.maxangle) or t.minangle)
            pitch = math.random()>0.5 and a or -a
        elseif t.pitchtype == "spinbot" then
            pitch = math.sin(tick()*(t.maxspeed/10))*math.rad(t.maxangle)
        elseif t.pitchtype == "random" then
            pitch = s.framecounter%20==0 and rndRange(math.rad(-89),math.rad(89)) or s.smoothpitch
        end
    end)
    return pitch
end

local function calcRoll()
    local t = antiAimSettings
    if t.angletype=="tilt 45"     then return math.rad(45)
    elseif t.angletype=="tilt 90" then return math.rad(90)
    elseif t.angletype=="upside down" then return math.rad(180)
    elseif t.angletype=="custom"  then return math.rad(t.customangle)
    end
    return 0
end

local function flushAntiAim()
    pcall(function()
        underground_oldpos = nil
        antiAimState.framecounter = 0
        antiAimState.smoothyaw    = 0
        antiAimState.smoothpitch  = 0
        antiAimState.smoothroll   = 0
        resetHeadMotors()
        local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if hrp then pcall(function() hrp.AssemblyAngularVelocity = Vector3.zero end) end
    end)
end

getgenv().InstanceFlushMovementState = flushAntiAim
getgenv().InstanceUndergroundEnabled = false
getgenv().InstanceSetUnderground = function(val)
    underground_enabled = val
    getgenv().InstanceUndergroundEnabled = val
