end

RunService.Heartbeat:Connect(function()
    pcall(function()
        if not antiAimSettings.enabled then return end
        if antiAimSettings.yawtype=="none" and antiAimSettings.pitchtype=="none" and antiAimSettings.angletype=="none" then return end
        local char = LocalPlayer.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        antiAimState.framecounter += 1
        hrp.CFrame = hrp.CFrame * CFrame.Angles(calcPitch(), calcYaw(), calcRoll())
    end)
end)

