        MenuFadeTime     = 0.2,
    })

    local Tabs = {
        VoidSpam   = Window:AddTab("Void Spam"),
        UISettings = Window:AddTab("UI Settings"),
    }

    local function safeRequireV(obj)
        local ok, result = pcall(require, obj)
        return ok and result or nil
    end

    local VoidLeft  = Tabs.VoidSpam:AddLeftGroupbox("Void Spam")
    local VoidRight = Tabs.VoidSpam:AddRightGroupbox("Settings")

    local voidHRPRef    = nil
    local savedClientC  = nil
    local savedClientV  = nil
    local savedClientVA = nil
    local lockedCameraC = nil
    local voidHBConn    = nil
    local velSpikeConn  = nil
    local antiAimConn   = nil
    local antiAimLocked = nil

    local VOID_X_MAX    = 450000
    local VOID_Y_MAX    = 590000
    local VOID_Z_MAX    = 230000
    local VoidIntensity = 1.0

    local function betterRandom(mi, ma, dmi, dma)
        local val = math.random(mi, ma)
        local attempts = 0
        repeat
            val = math.random(mi, ma)
            attempts += 1
        until val < dmi or val > dma or attempts > 20
        return val
    end

    local function getVoidPos()
        local xi = math.floor(VOID_X_MAX * VoidIntensity)
        local yi = math.floor(VOID_Y_MAX * VoidIntensity)
        local zi = math.floor(VOID_Z_MAX * VoidIntensity)
        local xe = math.floor(xi * 0.5)
        local ye = math.floor(yi * 0.5)
        local ze = math.floor(zi * 0.5)
        return Vector3.new(
            betterRandom(-xi, xi, -xe, xe),
            betterRandom(0,   yi,  0,  ye),
            betterRandom(-zi, zi, -ze, ze)
        )
    end

    local function getVoidVel()
        local xi = math.floor(VOID_X_MAX * VoidIntensity)
        local yi = math.floor(VOID_Y_MAX * VoidIntensity)
        local zi = math.floor(VOID_Z_MAX * VoidIntensity)
        return Vector3.new(math.random(-xi,xi),math.random(-yi,yi),math.random(-zi,zi))
    end

    local function lockCamera()
        lockedCameraC = workspace.CurrentCamera.CFrame
    end

    local function applyCameraLock()
        if lockedCameraC then workspace.CurrentCamera.CFrame = lockedCameraC end
    end

    local function startVoidSpam()
        if voidHBConn then voidHBConn:Disconnect();voidHBConn=nil end
        lockCamera()
        voidHBConn = RunService.Heartbeat:Connect(function()
            pcall(function()
                local char = lp.Character
                if not char then return end
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if not hrp then return end
                voidHRPRef   = hrp
                savedClientC  = hrp.CFrame
                savedClientV  = hrp.AssemblyLinearVelocity
                savedClientVA = hrp.AssemblyAngularVelocity
                local vPos = getVoidPos()
                hrp.CFrame = CFrame.new(vPos) * CFrame.Angles(math.pi,math.pi,math.pi)
                hrp.AssemblyLinearVelocity  = getVoidVel()
                hrp.AssemblyAngularVelocity = getVoidVel()
            end)
        end)
        RunService:BindToRenderStep("VoidSyncSA", Enum.RenderPriority.First.Value, function()
            if voidHRPRef and savedClientC then
                pcall(function()
                    voidHRPRef.CFrame = savedClientC
                    voidHRPRef.AssemblyLinearVelocity  = savedClientV
                    voidHRPRef.AssemblyAngularVelocity = savedClientVA
                end)
            end
            applyCameraLock()
        end)
    end

    local function stopVoidSpam()
        if voidHBConn then voidHBConn:Disconnect();voidHBConn=nil end
        pcall(function() RunService:UnbindFromRenderStep("VoidSyncSA") end)
        voidHRPRef=nil;lockedCameraC=nil
    end

    local velSpikeRate = 0.05
    local lastSpike    = 0

    local function startVelSpike()
        if velSpikeConn then velSpikeConn:Disconnect();velSpikeConn=nil end
        velSpikeConn = RunService.Heartbeat:Connect(function()
            if tick()-lastSpike < velSpikeRate then return end
            lastSpike = tick()
            pcall(function()
                local char = lp.Character
                if not char then return end
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if not hrp then return end
                hrp.AssemblyLinearVelocity = getVoidVel()
            end)
        end)
    end

    local function stopVelSpike()
        if velSpikeConn then velSpikeConn:Disconnect();velSpikeConn=nil end
    end

    local UpdateCamRemote = ReplicatedStorage
        :WaitForChild("Remotes"):WaitForChild("Replication")
        :WaitForChild("Fighter"):FindFirstChild("UpdateCameraRotation")

    local Utility = safeRequireV(ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Utility"))

    local function startAntiAim()
        antiAimLocked = Vector2.new(math.random()*math.pi*2, math.random()*math.pi*2)
        antiAimConn = RunService.Heartbeat:Connect(function()
            if not UpdateCamRemote then return end
            if not Utility then return end
            pcall(function()
                local encoded = Utility:EncodeCameraRotation(antiAimLocked)
                UpdateCamRemote:FireServer(encoded, nil)
            end)
        end)
    end

    local function stopAntiAim()
        if antiAimConn then antiAimConn:Disconnect();antiAimConn=nil end
        antiAimLocked=nil
    end

    VoidLeft:AddToggle("VoidSpam",{
        Text="Standard Void Spam",Default=false,Tooltip="TPs to void every frame then syncs back",
        Callback=function(v) if v then startVoidSpam();Library:Notify("Void Spam Active!",3) else stopVoidSpam();Library:Notify("Void Spam Off",2) end end,
    })
    VoidLeft:AddToggle("VelocitySpike",{
        Text="Velocity Spike",Default=false,Tooltip="Randomly spikes velocity every frame",
        Callback=function(v) if v then startVelSpike() else stopVelSpike() end end,
    })
    VoidLeft:AddDivider()
    VoidLeft:AddToggle("MetaVoidSpam",{
        Text="Meta Void Spam",Default=false,Risky=true,Tooltip="Void + Velocity Spike — meta combo",
        Callback=function(v)
            Toggles.VoidSpam:SetValue(v);Toggles.VelocitySpike:SetValue(v)
            if v then Library:Notify("Meta Void Spam Active!",3) else Library:Notify("Meta Void Spam Off",2) end
        end,
    })
    VoidLeft:AddDivider()
    VoidLeft:AddToggle("AntiAim",{
        Text="Anti Aim",Default=false,Risky=true,Tooltip="Sends fake camera rotation to server",
        Callback=function(v) if v then startAntiAim();Library:Notify("Anti Aim Active!",3) else stopAntiAim();Library:Notify("Anti Aim Off",2) end end,
    })
    VoidLeft:AddButton({
        Text="Stop All",
        Func=function()
            Toggles.VoidSpam:SetValue(false);Toggles.VelocitySpike:SetValue(false)
            Toggles.MetaVoidSpam:SetValue(false);Toggles.AntiAim:SetValue(false)
            Library:Notify("All features stopped!",2)
        end,
    })

    VoidRight:AddSlider("VoidIntensitySlider",{Text="Void Intensity",Default=100,Min=1,Max=100,Rounding=0,Suffix="%",Callback=function(v) VoidIntensity=v/100 end})
    VoidRight:AddSlider("VelSpikeRateSlider",{Text="Spike Rate",Default=5,Min=1,Max=20,Rounding=0,Suffix="x",Callback=function(v) velSpikeRate=0.1/v end})
    VoidRight:AddLabel("Void Ranges:\nY: 0-590,000\nX: 0-450,000\nZ: 0-230,000\n\nCamera locks when void enabled.",true)

    local MenuGroup=Tabs.UISettings:AddLeftGroupbox("Menu")
    MenuGroup:AddToggle("ShowCustomCursor",{Text="Custom Cursor",Default=true,Callback=function(v) Library.ShowCustomCursor=v end})
    MenuGroup:AddLabel("Menu Keybind"):AddKeyPicker("MenuKeybind",{Default="RightShift",NoUI=true,Text="Menu Keybind"})
    MenuGroup:AddButton({
        Text="Unload",
        Func=function()
            stopVoidSpam();stopVelSpike();stopAntiAim()
            Library:Unload()
        end,
    })

    Library.ToggleKeybind = Options.MenuKeybind

    Library:SetWatermarkVisibility(true)

    local frameTimer=tick();local frameCount=0;local currentFPS=60

    local function getPing()
        local ok,val=pcall(function()
            return math.floor(game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValue())
        end)
        return ok and val or 0
    end

    RunService.RenderStepped:Connect(function()
        frameCount+=1
        if tick()-frameTimer>=1 then currentFPS=frameCount;frameTimer=tick();frameCount=0 end
        Library:SetWatermark(("🌀 Void Hub | %d fps | %d ms"):format(currentFPS,getPing()))
    end)

    Library:OnUnload(function() Library.Unloaded=true end)

    if ThemeManager then ThemeManager:SetLibrary(Library) end
    if SaveManager then
        SaveManager:SetLibrary(Library)
        SaveManager:IgnoreThemeSettings()
        SaveManager:SetIgnoreIndexes({"MenuKeybind"})
        SaveManager:SetFolder("RivalsHub")
        SaveManager:SetFolder("RivalsHub/VoidSpam")
        SaveManager:BuildConfigSection(Tabs.UISettings)
        if ThemeManager then ThemeManager:SetFolder("RivalsHub");ThemeManager:ApplyToTab(Tabs.UISettings) end
        SaveManager:LoadAutoloadConfig()
    end

    Library:Notify("🌀 Void Spam Hub Loaded! RightShift to toggle.",5)

end -- end loadVoidSpamScript
