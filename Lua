    --   Fighter Helpers
    -- =============================================

    local function getLocalFighter()
        if not FighterController then return nil end
        local ok, f = pcall(function() return FighterController.LocalFighter end)
        return ok and f or nil
    end

    local function getAllItems()
        local items = {}
        local fighter = getLocalFighter()
        if not fighter then return items end
        if fighter.Items then
            for _, item in pairs(fighter.Items) do
                table.insert(items, item)
            end
        end
        return items
    end

    local function getItemByName(name)
        for _, item in pairs(getAllItems()) do
            if item.Name == name then return item end
        end
        return nil
    end

    local function getPlayerList()
        local list = {}
        for _, p in pairs(Players:GetPlayers()) do
