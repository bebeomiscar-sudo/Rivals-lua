    NFrame.BackgroundColor3 = Theme.Secondary
    NFrame.BorderSizePixel  = 0
    NFrame.ClipsDescendants = true
    NFrame.ZIndex           = 1000
    NFrame.LayoutOrder      = notifCount
    NFrame.Parent           = NotifContainer
    Instance.new("UICorner", NFrame).CornerRadius = UDim.new(0,10)

    local NAccent = Instance.new("Frame")
    NAccent.Size             = UDim2.new(0,3,1,0)
    NAccent.BackgroundColor3 = color
    NAccent.BorderSizePixel  = 0
    NAccent.ZIndex           = 1001
    NAccent.Parent           = NFrame

    local NTitle = Instance.new("TextLabel")
    NTitle.Size               = UDim2.new(1,-16,0,20)
    NTitle.Position           = UDim2.new(0,12,0,8)
    NTitle.BackgroundTransparency = 1
    NTitle.Text               = title
    NTitle.TextColor3         = color
    NTitle.TextSize           = 13
    NTitle.Font               = Enum.Font.GothamBold
    NTitle.TextXAlignment     = Enum.TextXAlignment.Left
    NTitle.ZIndex             = 1001
    NTitle.Parent             = NFrame

    local NMsg = Instance.new("TextLabel")
    NMsg.Size               = UDim2.new(1,-16,0,18)
    NMsg.Position           = UDim2.new(0,12,0,28)
    NMsg.BackgroundTransparency = 1
    NMsg.Text               = message
    NMsg.TextColor3         = Theme.TextDim
    NMsg.TextSize           = 12
    NMsg.Font               = Enum.Font.Gotham
    NMsg.TextXAlignment     = Enum.TextXAlignment.Left
    NMsg.ZIndex             = 1001
    NMsg.Parent             = NFrame

    local ProgBg = Instance.new("Frame")
    ProgBg.Size             = UDim2.new(1,0,0,3)
    ProgBg.Position         = UDim2.new(0,0,1,-3)
    ProgBg.BackgroundColor3 = Theme.SliderBg
    ProgBg.BorderSizePixel  = 0
    ProgBg.ZIndex           = 1001
    ProgBg.Parent           = NFrame

    local ProgFill = Instance.new("Frame")
    ProgFill.Size             = UDim2.new(1,0,1,0)
    ProgFill.BackgroundColor3 = color
    ProgFill.BorderSizePixel  = 0
    ProgFill.ZIndex           = 1002
    ProgFill.Parent           = ProgBg

    Tween(NFrame, {Size=UDim2.new(1,0,0,55)}, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    Tween(ProgFill, {Size=UDim2.new(0,0,1,0)}, duration or 4, Enum.EasingStyle.Linear)

    task.delay(duration or 4, function()
        Tween(NFrame, {Size=UDim2.new(1,0,0,0), BackgroundTransparency=1}, 0.3)
        task.delay(0.3, function() NFrame:Destroy() end)
    end)
end

