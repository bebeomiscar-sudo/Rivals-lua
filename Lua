--// ============================================================

UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.Insert then
        MainFrame.Visible = not MainFrame.Visible
    end

    -- Aimbot hold mode
    if not isMobile and aimbot.keyMode == "hold" and aimbot.masterEnabled then
        if input.KeyCode == Enum.KeyCode.C then
            aimbot.enabled = true
            updaimbot()
        end
    end

    -- Ragebot manual key
    if input.KeyCode == Enum.KeyCode.E and Config.RagebotEnabled then
        if not rageConfig.target.enabled then
            local target = nearest()
            if target then
                settarget(target)
                rageConfig.target.manualkey = true
            end
        else
            cleartarget()
        end
    end
end)

UserInputService.InputEnded:Connect(function(input, gp)
    if gp then return end
    if not isMobile and aimbot.keyMode == "hold" then
        if input.KeyCode == Enum.KeyCode.C then
            aimbot.enabled = false
            clearAimbotLock()
            updaimbot()
        end
    end
end)

