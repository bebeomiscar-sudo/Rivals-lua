-- =============================================
--   Crash Prevention — Yield Budget Guard
--   Prevents UI from freezing Roblox on load
-- =============================================

local function safeWait(t)
    -- Uses heartbeat instead of task.wait
    -- so UI thread stays alive and doesn't choke
    local start = tick()
    local conn
    conn = RunService.Heartbeat:Connect(function()
        if tick() - start >= t then
            conn:Disconnect()
        end
    end)
    -- Still need to yield the calling thread
    while tick() - start < t do
        RunService.Heartbeat:Wait()
    end
end

