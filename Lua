        ob.MouseEnter:Connect(function() if ob.Text~=cur then TweenQuick(ob,{BackgroundColor3=Color3.fromRGB(35,35,55)}) end end)
        ob.MouseLeave:Connect(function() if ob.Text~=cur then TweenQuick(ob,{BackgroundColor3=Color3.fromRGB(25,25,40)}) end end)
    end

    vb.MouseButton1Click:Connect(function()
        open=not open; df.Visible=open
        Tween(vb,{BackgroundColor3=open and Theme.Accent or Theme.AccentDark},0.15)
    end)
    return f
end

