    local function teleportToPlayer(player)
        if not isPlayerInGame(player) then
            Library:Notify(player.Name .. " is in lobby — skipped!", 3)
            return false
        end
        local char   = player.Character
        local myChar = lp.Character
        if not char or not myChar then return false end
        local tHRP  = char:FindFirstChild("HumanoidRootPart")
        local myHRP = myChar:FindFirstChild("HumanoidRootPart")
        if not tHRP or not myHRP then return false end
        myHRP.CFrame = CFrame.new(tHRP.Position + Vector3.new(0, 5, 0))
        if tpConfig.stayOnTop then startStayOnTop(player) end
        Library:Notify("Teleported to " .. player.Name, 2)
