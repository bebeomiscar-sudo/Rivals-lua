            local function rageGetClosest()
                if not lp2.Character or not lp2.Character:FindFirstChild("HumanoidRootPart") then return nil,nil end
                local target,char,dist=nil,nil,math.huge
                for _,v in pairs(Players2:GetPlayers()) do
                    if v~=lp2 and v.Character and v.Character:FindFirstChild("Head") then
                        local mag=(lp2.Character.HumanoidRootPart.Position-v.Character.Head.Position).Magnitude
                        if mag<dist then dist=mag;target=v.Character.Head;char=v.Character end
                    end
                end
                return target,char
            end

            local function rageCalcPoint(orig2,targetPos,targetChar)
                ray_p.FilterDescendantsInstances={lp2.Character,targetChar}
                if not ws:Raycast(orig2,targetPos-orig2,ray_p) then return orig2,nil end
                for _,offset in next,rageCfg.vectors do
                    local sp=orig2+offset
                    if not ws:Raycast(sp,targetPos-sp,ray_p) then return sp,offset.Y end
                end
                return nil,nil
            end

            local function improvedCalcPoint(orig2,targetPos,targetChar)
                ray_p.FilterDescendantsInstances={lp2.Character,targetChar}
                local function tryPoint(sp)
                    local r=ws:Raycast(sp,targetPos-sp,ray_p)
                    return r==nil or r.Instance:IsDescendantOf(targetChar)
                end
                if tryPoint(orig2) then return orig2,nil end
                for _,offset in next,rageCfg.vectors do
                    local sp=orig2+offset
                    if tryPoint(sp) then return sp,offset.Y end
                end
                if rageCfg.improv.multiPass then
                    local step=rageCfg.improv.scanAngle
                    for _,offset in next,rageCfg.vectors do
                        for angle=-45,45,step do
                            local rad=math.rad(angle)
                            local rx=offset.X*math.cos(rad)-offset.Z*math.sin(rad)
                            local rz=offset.X*math.sin(rad)+offset.Z*math.cos(rad)
                            local sp=orig2+Vector3.new(rx,offset.Y,rz)
                            if tryPoint(sp) then return sp,offset.Y end
                        end
                    end
                end
                if rageCfg.improv.spiralScan then
                    for layer=1,4 do
                        local h=layer*8
                        for step2=0,11 do
                            local a=(step2/12)*math.pi*2
                            local sp=orig2+Vector3.new(math.cos(a)*2*layer,h,math.sin(a)*2*layer)
                            if tryPoint(sp) then return sp,h end
                        end
                    end
                end
                local sides={
                    Vector3.new(2,0,0),Vector3.new(-2,0,0),
                    Vector3.new(0,0,2),Vector3.new(0,0,-2),
                    Vector3.new(3,8,0),Vector3.new(-3,8,0),
                    Vector3.new(0,8,3),Vector3.new(0,8,-3),
                }
                for _,side in next,sides do
                    local sp=orig2+side
                    if tryPoint(sp) then return sp,side.Y end
                end
                if rageCfg.improv.adaptDist then
                    local dist2=(orig2-targetPos).Magnitude
                    local scale=math.clamp(dist2/50,0.5,3)
                    for _,offset in next,rageCfg.vectors do
                        local sc=Vector3.new(offset.X*scale,offset.Y*scale,offset.Z*scale)
                        local sp=orig2+sc
                        if tryPoint(sp) then return sp,sc.Y end
                    end
                end
                return nil,nil
            end

            local function startRagebot()
                if rageConn then rageConn:Disconnect();rageConn=nil end
                rageRunning=false
                rageConn=RunService2.Heartbeat:Connect(function()
                    if not rageCfg.enabled then return end
