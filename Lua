local function randVs(a, b)
    a = math.clamp(tonumber(a) or 1, 0.1, 2)
    b = math.clamp(tonumber(b) or 1, 0.1, 2)
    if b<a then a,b=b,a end
    return a==b and a or a+math.random()*(b-a)
end

local function isteammate(p)
    if not p then return false end
    local ok1,t1 = pcall(function() return LocalPlayer:GetAttribute("TeamID") end)
    local ok2,t2 = pcall(function() return p:GetAttribute("TeamID") end)
    return ok1 and ok2 and t1 and t2 and t1==t2
end

local function valid(char)
    if not char or not char.Parent then return false end
    local ok, r = pcall(function()
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health<=0 then return false end
        if not char:FindFirstChild("HumanoidRootPart") then return false end
        local tp = Players:GetPlayerFromCharacter(char)
        return tp and not isteammate(tp)
    end)
    return ok and r or false
end

local function nearest()
    local ok, r = pcall(function()
        local cur = UserInputService:GetMouseLocation()
        local best, bestD = nil, math.huge
        for _, p in Players:GetPlayers() do
            if p ~= LocalPlayer and p.Character and valid(p.Character) then
                local root = p.Character:FindFirstChild("HumanoidRootPart")
                if root then
                    local sp, on = worldToScreen(root.Position, Camera)
                    if on and sp then
                        local d = (Vector2.new(sp.X,sp.Y)-cur).Magnitude
                        if d<bestD then best=p.Character; bestD=d end
                    end
                end
            end
        end
        return best
    end)
    return ok and r or nil
end

local function hitPartFromName(char, name)
    if not char then return nil end
    local ok, r = pcall(function()
        if name=="Closest" then
            local myHRP = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if not myHRP then return char:FindFirstChild("Head") end
            local cl,cd = nil,math.huge
            for _, p in pairs(char:GetChildren()) do
                if p:IsA("BasePart") then
                    local d=(p.Position-myHRP.Position).Magnitude
                    if d<cd then cd=d; cl=p end
                end
            end
            return cl or char:FindFirstChild("Head")
        elseif name=="Random" then
            local pts={"Head","HumanoidRootPart","UpperTorso"}
            return char:FindFirstChild(pts[math.random(#pts)]) or char:FindFirstChild("Head")
        else
            return char:FindFirstChild(name) or char:FindFirstChild("Head")
        end
    end)
    return ok and r or nil
end

local function predictPos(part, origin)
    if not rageConfig.prediction.enabled or not part then
        return part and part.Position or Vector3.new()
    end
    local ok, r = pcall(function()
        local base = part.Position
        local dist = (base-origin).Magnitude
        local ping = 0
        pcall(function()
            ping = Stats.Network.ServerStatsItem["Data Ping"]:GetValue()/1000
        end)
        return base + rageConfig.prediction.velocity * ((dist/3000+ping)*rageConfig.prediction.multiplier)
    end)
    return ok and r or (part and part.Position or Vector3.new())
end

local function updateVel()
    pcall(function()
        if not rageConfig.target.character or not rageConfig.prediction.enabled then
            rageConfig.prediction.velocity = Vector3.new()
            rageConfig.prediction.lastposition = nil
            return
        end
        local root = rageConfig.target.character:FindFirstChild("HumanoidRootPart")
        if not root then return end
        local now = tick()
        local dt2 = now - rageConfig.prediction.lasttime
        if dt2>0 and dt2<0.1 and rageConfig.prediction.lastposition then
            rageConfig.prediction.velocity = rageConfig.prediction.velocity:Lerp(
                (root.Position-rageConfig.prediction.lastposition)/dt2, 0.6
            )
        end
        rageConfig.prediction.lastposition = root.Position
        rageConfig.prediction.lasttime     = now
    end)
end

local function tickVS()
    pcall(function()
        if not rageConfig.voidspam.enabled then return end
        local now = tick()
        local el  = now - rageConfig.voidspam.lastswitch
        local vs  = rageConfig.voidspam
        if vs.phase=="shoot" then
            if el>=vs.currentduration then
                vs.phase="hide"; vs.currentduration=randVs(vs.hide_min,vs.hide_max); vs.lastswitch=now
            end
        elseif vs.phase=="hide" then
            if el>=vs.currentduration then
                vs.phase="shoot"; vs.currentduration=randVs(vs.shoot_min,vs.shoot_max); vs.lastswitch=now
            end
        else
            vs.phase="shoot"; vs.currentduration=randVs(vs.shoot_min,vs.shoot_max); vs.lastswitch=now
        end
    end)
end

local function atkCfg()
    if rageConfig.target.attackPosition=="under" then
        return {height=0,front=0,side=0,vertical=-(rageConfig.target.underOffset or 4),radius=0}
    end
    local w = getweapon()
    return {height=(w and w:lower():find("sniper")) and 8 or 2,front=0,side=0,vertical=0,radius=0}
end

local function orbBase(root)
    if not root then return Vector3.zero end
    local s = atkCfg()
    return root.Position + root.CFrame.LookVector*s.front + root.CFrame.RightVector*s.side + Vector3.new(0,s.vertical,0)
end

local function stopsync()
    pcall(function()
        if not rageConfig.state.csyncactive then return end
        if rageConfig.orbit.connection then
            rageConfig.orbit.connection:Disconnect()
            rageConfig.orbit.connection = nil
        end
        rageConfig.state.csyncactive = false
        rageConfig.orbit.active      = false
        clrSnap()
        rageConfig.voidspam.phase = nil
        if rageConfig.orbit.savedpos and localfighter and localfighter.Entity and localfighter.Entity.RootPart then
            pcall(function() localfighter.Entity.RootPart.CFrame = rageConfig.orbit.savedpos end)
        end
        rageConfig.orbit.serverpos = nil
        rageConfig.orbit.savedpos  = nil
        oldpos_rg = nil
    end)
end

local function startsync()
    pcall(function()
        if rageConfig.state.csyncactive or rageConfig.target.immune then return end
        if not rageConfig.target.character or not valid(rageConfig.target.character) then return end
        rageConfig.state.csyncactive = true
        rageConfig.orbit.active      = true
        local s = atkCfg()
        rageConfig.orbit.height = s.height
        rageConfig.orbit.radius = s.radius or 0
        if localfighter and localfighter.Entity and localfighter.Entity.RootPart then
            rageConfig.orbit.savedpos = localfighter.Entity.RootPart.CFrame
        end
        rageConfig.orbit.connection = RunService.Heartbeat:Connect(function(dt2)
            pcall(function()
                if not rageConfig.state.csyncactive then return end
                if rageConfig.target.immune then stopsync() return end
                if not rageConfig.target.character or not valid(rageConfig.target.character) then stopsync() return end
                if not localfighter or not localfighter.Entity or not localfighter.Entity.RootPart then stopsync() return end

                oldpos_rg = localfighter.Entity.RootPart.CFrame

                local _w = getweapon()
                local _sl = isSling(_w)

                if rageConfig.voidspam.enabled then
                    tickVS()
                    if rageConfig.voidspam.phase=="hide" then
                        rageConfig.orbit.serverpos = Vector3.new(math.random(-10000,10000),-99999999999,math.random(-10000,10000))
                        pcall(function() localfighter.Entity.RootPart.CFrame = CFrame.new(rageConfig.orbit.serverpos) end)
                        return
                    end
                end

                local root = rageConfig.target.character:FindFirstChild("HumanoidRootPart")
                if not root then stopsync() return end

                if rageConfig.state.outofammo and not _sl and _w and not isInfiniteWeapon() then
                    local hrp = voidHrp()
                    if hrp then snapVoid(hrp)
                    else
                        rageConfig.orbit.serverpos = Vector3.new(math.random(-10000,10000),-99999999999,math.random(-10000,10000))
                        pcall(function() localfighter.Entity.RootPart.CFrame = CFrame.new(rageConfig.orbit.serverpos) end)
                    end
                    return
                end

                rageConfig.orbit.angle += rageConfig.orbit.speed*dt2
                rageConfig.orbit.serverpos = orbBase(root) + Vector3.new(
                    math.cos(rageConfig.orbit.angle)*rageConfig.orbit.radius,
                    rageConfig.orbit.height,
                    math.sin(rageConfig.orbit.angle)*rageConfig.orbit.radius
                )

                if not getgenv().InstanceUndergroundEnabled then
                    local cur = localfighter.Entity.RootPart.CFrame
                    local nw  = CFrame.new(rageConfig.orbit.serverpos)
                    if (nw.Position-cur.Position).Magnitude < 2000 then
                        localfighter.Entity.RootPart.CFrame = nw
                        rageConfig.orbit.savedpos = cur
                    end
                end
            end)
        end)
    end)
end

local function autoshoot()
    pcall(function()
        if rageConfig.voidspam.enabled and rageConfig.voidspam.phase=="hide" then return end
        if not rageConfig.target.enabled or not rageConfig.target.character or not rageConfig.target.autoshoot then return end
        if rageConfig.target.immune then return end
        if not Modules.fighter or not Modules.utility or not Modules.enums then return end
        local lf = Modules.fighter.LocalFighter
        if not lf or not lf.EquippedItem then return end
        if not isInfiniteWeapon() then
            if rageConfig.state.reloading or rageConfig.state.outofammo then return end
        end
        local tc = rageConfig.target.character
        if not valid(tc) then return end
        local hp = hitPartFromName(tc, rageConfig.target.hitpart)
        if not hp then return end
        local sp
        if rageConfig.state.csyncactive and rageConfig.orbit.serverpos then
            sp = rageConfig.orbit.serverpos
        else
            local myhrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            sp = myhrp and myhrp.Position or Vector3.new()
        end
        local tp = predictPos(hp, sp)
        local ok2, sCF = pcall(function() return Modules.utility:EncodeCFrame(CFrame.new(sp,tp)) end)
        if not ok2 or not sCF then return end
        local data = {
            [utf8.char(1)] = {
                [utf8.char(0)] = sCF,
                [utf8.char(1)] = sCF,
                [utf8.char(2)] = hp,
                [utf8.char(3)] = Modules.utility:EncodeCFrame(CFrame.new(0.43,0.25,0.42)),
            }
        }
        local eq = lf.EquippedItem
        local oid = eq and eq:Get("ObjectID")
        if not oid then return end
        local sEnum = Modules.enums:ToEnum("StartShooting")
        if not sEnum then return end
        local ok3, useItem = pcall(function()
            return ReplicatedStorage.Remotes.Replication.Fighter.UseItem
        end)
        if not ok3 or not useItem then return end
        local att = math.clamp(math.floor(tonumber(rageConfig.target.shootAttempts) or 1),1,3)
        for _ = 1, att do
            pcall(useItem.FireServer, useItem, oid, sEnum, data, nil)
        end
    end)
end

local function cleartarget()
    pcall(function()
        rageConfig.target.enabled   = false
        stopsync()
        rageConfig.target.character  = nil
        rageConfig.target.lastchar   = nil
        rageConfig.target.lastplayer = nil
        rageConfig.target.manualkey  = false
        rageConfig.target.immune     = false
    end)
end

local function settarget(char)
    if not char then return end
    pcall(function()
        rageConfig.target.enabled    = true
        rageConfig.target.character  = char
        rageConfig.target.lastchar   = char
        rageConfig.target.lastplayer = Players:GetPlayerFromCharacter(char)
        rageConfig.target.immune     = false
        local root = char:FindFirstChild("HumanoidRootPart")
        if root and root:FindFirstChild("Attachment") then
            rageConfig.target.immune = true
        else
            startsync()
        end
    end)
end

RunService.Heartbeat:Connect(function()
    pcall(function()
        for _, plr in pairs(Players:GetPlayers()) do
            if plr==LocalPlayer then continue end
            local char  = plr.Character
            local root  = char and char:FindFirstChild("HumanoidRootPart")
            local imm   = root and root:FindFirstChild("Attachment") ~= nil
            if imm and not immuneList[plr.Name] then
                immuneList[plr.Name] = true
                for _, cb in pairs(onImmune) do pcall(cb,plr) end
            elseif not imm and immuneList[plr.Name] then
                immuneList[plr.Name] = nil
                for _, cb in pairs(onVulnerable) do pcall(cb,plr) end
            end
        end
    end)
end)

table.insert(onImmune, function(plr)
    if rageConfig.target.lastplayer==plr then
        rageConfig.target.immune=true; clrSnap(); stopsync()
    end
end)
table.insert(onVulnerable, function(plr)
    if rageConfig.target.lastplayer==plr then
        rageConfig.target.immune=false
        if rageConfig.target.enabled and rageConfig.target.character and valid(rageConfig.target.character) then
            startsync()
        end
    end
end)

RunService.Heartbeat:Connect(function()
    pcall(function()
        if rageConfig.prediction.enabled and rageConfig.target.character then updateVel() end
        if rageConfig.target.auto and not rageConfig.target.manualkey then
            if not rageConfig.target.enabled or not rageConfig.target.character or not valid(rageConfig.target.character) then
                local nt = nearest()
                if nt then
                    if rageConfig.target.enabled then stopsync() end
                    settarget(nt)
                end
            end
        end
        if rageConfig.target.enabled and rageConfig.target.character then
            if not valid(rageConfig.target.character) then cleartarget() return end
            if rageConfig.target.autoshoot and not rageConfig.target.immune then autoshoot() end
        end
    end)
end)

