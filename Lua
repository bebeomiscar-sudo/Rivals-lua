function loadRivalsScript()

    -- =============================================
    --   Load Linoria Library
    -- =============================================

    local repo = "https://raw.githubusercontent.com/xyznick/UELinoriaLib/main/"

    local Library, ThemeManager, SaveManager

    -- Load in stages with heartbeat waits
    -- so no single frame gets overloaded
    local ok1, lib = pcall(function()
        return loadstring(game:HttpGet(repo .. "Library.lua"))()
    end)
    if not ok1 then warn("Library load failed: " .. tostring(lib)) return end
    Library = lib

    RunService.Heartbeat:Wait()

    local ok2, tm = pcall(function()
        return loadstring(game:HttpGet(repo .. "addons/ThemeManager.lua"))()
    end)
    if not ok2 then warn("ThemeManager load failed") return end
    ThemeManager = tm

    RunService.Heartbeat:Wait()

    local ok3, sm = pcall(function()
        return loadstring(game:HttpGet(repo .. "addons/SaveManager.lua"))()
    end)
    if not ok3 then warn("SaveManager load failed") return end
    SaveManager = sm

    RunService.Heartbeat:Wait()

    local Options = getgenv().Options
    local Toggles = getgenv().Toggles

    Library.ShowCustomCursor = true
    Library.NotifySide       = "Left"

    -- =============================================
    --   Services (already declared above globally)
    -- =============================================

    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local UserInputService  = game:GetService("UserInputService")

    -- =============================================
    --   Window
    -- =============================================

    local Window = Library:CreateWindow({
        Title            = "Rivals Hub",
        Center           = true,
        AutoShow         = true,
        Resizable        = true,
        ShowCustomCursor = true,
        TabPadding       = 8,
        MenuFadeTime     = 0.2,
    })

    -- =============================================
    --   Tabs
    -- =============================================

