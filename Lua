local function getrandominrange(min, max)
    return min + math.random() * (max - min)
end

local function curweap2()
    local vm = workspace:FindFirstChild("ViewModels")
    if not vm then return nil end
    local fp = vm:FindFirstChild("FirstPerson")
    if not fp then return nil end
    for _, child in ipairs(fp:GetChildren()) do
        local parts = {}
        for part in child.Name:gmatch("[^-]+") do
            table.insert(parts, part:match("^%s*(.-)%s*$"))
        end
        if #parts >= 2 then return parts[2] end
    end
    return nil
end

local headBackwardsMotors  = {}
local headBackwardsOrigC0  = {}

local function updateHeadBackwardsMotors()
    headBackwardsMotors = {}
    headBackwardsOrigC0 = {}
    local character = LocalPlayer.Character
    if not character then return end
    for _, v in pairs(character:GetDescendants()) do
        if v:IsA("Motor6D") then
            headBackwardsMotors[v.Name] = v
            headBackwardsOrigC0[v] = v.C0
        end
    end
end

local function resetHeadBackwardsMotors()
    for motor, origC0 in pairs(headBackwardsOrigC0) do
        if motor and motor.Parent then motor.C0 = origC0 end
    end
end

local function calculateYaw(dt)
    local yaw = 0
    local t   = antiAimSettings
    local st  = antiAimState
    if t.yawtype == "jitter" then
        local minA = math.rad(t.minangle)
        local maxA = math.rad(t.maxangle)
        yaw = t.randomangle and getrandominrange(-maxA, maxA) or (math.random()>0.5 and minA or -minA)
    elseif t.yawtype == "spinbot" then
        local speed = getrandominrange(t.minspeed/10, t.maxspeed/10)
        yaw = (tick()*speed) % (2*math.pi)
    elseif t.yawtype == "random" then
        if st.framecounter % 30 == 0 then
            yaw = getrandominrange(-math.rad(t.maxangle), math.rad(t.maxangle))
        else
            yaw = st.smoothyaw
        end
    end
    return yaw
end

local function calculatePitch()
    local pitch = 0
    local t     = antiAimSettings
    local st    = antiAimState
    if t.pitchtype == "jitter" then
        local minA = math.rad(t.minangle)
        local maxA = math.rad(t.maxangle)
        pitch = t.randomangle and getrandominrange(-maxA, maxA) or (math.random()>0.5 and minA or -minA)
    elseif t.pitchtype == "spinbot" then
        pitch = math.sin(tick()*(t.maxspeed/10)) * math.rad(t.maxangle)
    elseif t.pitchtype == "random" then
        if st.framecounter % 20 == 0 then
            pitch = getrandominrange(math.rad(-89), math.rad(89))
        else
            pitch = st.smoothpitch
        end
    end
    return pitch
end

local function calculateRoll()
    local t = antiAimSettings
    if t.angletype == "tilt 45"     then return math.rad(45)
    elseif t.angletype == "tilt 90" then return math.rad(90)
    elseif t.angletype == "upside down" then return math.rad(180)
    elseif t.angletype == "custom"  then return math.rad(t.customangle)
    end
    return 0
end

local function flushAntiAimState()
    underground_oldpos = nil
    antiAimState.framecounter = 0
    antiAimState.smoothyaw    = 0
    antiAimState.smoothpitch  = 0
    antiAimState.smoothroll   = 0
    resetHeadBackwardsMotors()
    local char = LocalPlayer.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    if hrp then
        pcall(function() hrp.AssemblyAngularVelocity = Vector3.zero end)
    end
end

getgenv().InstanceFlushMovementState   = flushAntiAimState
getgenv().InstanceUndergroundEnabled   = false
getgenv().InstanceSetUnderground = function(val)
    underground_enabled = val
    getgenv().InstanceUndergroundEnabled = val
    if not val then underground_oldpos = nil end
end

local function updantiaim(dt)
    if not antiAimSettings.enabled then return end
    if antiAimSettings.yawtype == "none" and antiAimSettings.pitchtype == "none" and antiAimSettings.angletype == "none" then return end
    if not curweap2() then return end
    local char = LocalPlayer.Character
    if not char then return end
    local rootpart = char:FindFirstChild("HumanoidRootPart")
    if not rootpart then return end
    antiAimState.framecounter += 1
    local yaw   = calculateYaw(dt)
    local pitch = calculatePitch()
    local roll  = calculateRoll()
    rootpart.CFrame = rootpart.CFrame * CFrame.Angles(pitch, yaw, roll)
end

RunService.Heartbeat:Connect(updantiaim)

LocalPlayer.CharacterAdded:Connect(function()
    task.defer(function()
        flushAntiAimState()
        updateHeadBackwardsMotors()
    end)
end)

