        ol.Thickness=4*tracerSize; ol.Color=Color3.new(0,0,0)
        ol.Transparency=1; ol.Visible=false
        local ln = Drawing.new("Line")
        ln.Thickness=2*tracerSize; ln.Color=tracerColor
        ln.Transparency=1; ln.Visible=false
        table.insert(tracers,{IsLine=true,Outline=ol,Line=ln,
            StartPos=s,EndPos=e,Lifetime=tracerDuration,
            FadeTime=tracerFadeTime,CreatedTime=tick()})
    end)
end

local function makeBeamTracer(s,e)
    pcall(function()
        local a0=Instance.new("Attachment"); a0.Parent=workspace.Terrain
        local a1=Instance.new("Attachment"); a1.Parent=workspace.Terrain
        local bm=Instance.new("Beam")
        bm.Attachment0=a0; bm.Attachment1=a1
        bm.Color=ColorSequence.new(tracerColor)
        local bw=tracerStyle=="Laser" and 0.02 or 0.15
        bm.Width0=bw*tracerSize; bm.Width1=bw*tracerSize
        bm.Transparency=NumberSequence.new(0)
        bm.FaceCamera=true; bm.LightEmission=0.8; bm.LightInfluence=0.2
        local tx=textureAssets[tracerStyle]
        if tx and tx~="" then bm.Texture=tx; bm.TextureLength=4; bm.TextureSpeed=1 end
        bm.Parent=workspace.Terrain
        a0.WorldPosition=s; a1.WorldPosition=e
        table.insert(tracers,{IsLine=false,Beam=bm,Attachment0=a0,Attachment1=a1,
            StartPos=s,EndPos=e,Lifetime=tracerDuration,
            FadeTime=tracerFadeTime,CreatedTime=tick()})
    end)
end

local function maketracer(s,e)
    if not tracerEnabled or not s or not e then return end
    pcall(function()
        local k = math.floor(s.X*5+.5)*1e9+math.floor(s.Y*5+.5)*1e6+math.floor(s.Z*5+.5)*1e3
                + math.floor(e.X*5+.5)+math.floor(e.Y*5+.5)*1e-3+math.floor(e.Z*5+.5)*1e-6
        local now = tick()
        if lastTC[k] and now-lastTC[k]<DDUPE_INT then return end
        lastTC[k]=now
        if tracerStyle=="Line" then makeLineTracer(s,e) else makeBeamTracer(s,e) end
    end)
end

local function destroyTracer(t)
    pcall(function()
        if t.IsLine then
            if t.Outline then t.Outline:Remove() end
            if t.Line    then t.Line:Remove()    end
        else
            if t.Beam        then t.Beam:Destroy()        end
            if t.Attachment0 then t.Attachment0:Destroy() end
            if t.Attachment1 then t.Attachment1:Destroy() end
        end
    end)
end

local function updtracers()
    if #tracers==0 then return end
    pcall(function()
        frameCount+=1
        local now = tick()
        local cam = Camera or workspace.CurrentCamera
        local myChar = LocalPlayer.Character
        local myPos  = myChar and myChar:FindFirstChild("HumanoidRootPart") and myChar.HumanoidRootPart.Position
        if frameCount%DDUPE_PRUNE==0 then
            for k,t2 in next,lastTC do if now-t2>DDUPE_EXP then lastTC[k]=nil end end
        end
        local i=#tracers
        while i>=1 do
            local tr=tracers[i]
            local age=now-tr.CreatedTime
            if age>=tr.Lifetime then
                destroyTracer(tr)
                tracers[i]=tracers[#tracers]; tracers[#tracers]=nil
            else
                local fs=tr.Lifetime-tr.FadeTime
                local fa=age>=fs and 1-math.clamp((age-fs)/tr.FadeTime,0,1) or 1
                if tr.IsLine then
                    local vis=false
                    local de=tracerDrawEnd(tr,age)
                    local cp=cam and cam.CFrame.Position
                    local nc=cp and (tr.StartPos-cp).Magnitude<=12
                    if nc or not myPos or (tr.StartPos-myPos).Magnitude>2 then
                        local s2,os2=worldToScreen(tr.StartPos,cam)
                        local e2,oe2=worldToScreen(de,cam)
                        if os2 and oe2 and s2 and e2 then
                            local sx,sy=s2.X,s2.Y
                            local ex2,ey2=e2.X,e2.Y
                            if math.abs(sx)<20000 and math.abs(sy)<20000
                                and math.abs(ex2)<20000 and math.abs(ey2)<20000 then
                                local len=math.sqrt((ex2-sx)^2+(ey2-sy)^2)
                                if len>0.1 and len<3000 then
                                    local f2s=Vector2.new(sx,sy)
                                    local f2e=Vector2.new(ex2,ey2)
                                    tr.Outline.From=f2s; tr.Outline.To=f2e
                                    tr.Outline.Transparency=fa; tr.Outline.Visible=true
                                    tr.Line.From=f2s; tr.Line.To=f2e
                                    tr.Line.Transparency=fa; tr.Line.Visible=true
                                    vis=true
                                end
                            end
                        end
                    end
                    if not vis then tr.Outline.Visible=false; tr.Line.Visible=false end
                else
                    local de=tracerDrawEnd(tr,age)
                    if tr.Attachment0 then tr.Attachment0.WorldPosition=tr.StartPos end
                    if tr.Attachment1 then tr.Attachment1.WorldPosition=de end
                    tr.Beam.Transparency=NumberSequence.new(1-fa)
                end
            end
            i-=1
        end
    end)
end

local function hookTracerEffect()
    if tracerHooked then return end
    pcall(function()
        local te = safeFind(LocalPlayer,"PlayerScripts","Modules","TracerEffect")
        if not te then return end
        local TE = require(te)
        if not TE or not TE.Play then return end
        local orig = TE.Play
        TE.Play = function(self, td, cfg2, ex)
            if tracerEnabled and td and td.IsLocal and td.RaycastResults then
                local mp = muzzlepos()
                if mp then
                    for _, hit in ipairs(td.RaycastResults) do
                        if hit.Position then pcall(maketracer, mp, hit.Position) end
                    end
                end
            end
            return orig(self, td, cfg2, ex)
        end
        tracerHooked = true
    end)
end

task.defer(function()
    if tracerconn then tracerconn:Disconnect() end
    tracerconn = RunService.RenderStepped:Connect(updtracers)
    for _=1,30 do
        if tracerHooked then break end
        hookTracerEffect()
        task.wait(0.5)
    end
end)

