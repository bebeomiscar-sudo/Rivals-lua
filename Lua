--   Selection Handler
-- =============================================

local function onScriptSelected(scriptName)
    if selectedScript then return end
    selectedScript = scriptName
    timerDone      = true

    local flashColor = scriptName == "Rivals"
        and Color3.fromRGB(100, 80, 255)
        or  Color3.fromRGB(255, 80, 130)

    SubLabel.Text = "Loading " .. scriptName .. "..."
    TweenService:Create(SubLabel, TweenInfo.new(0.3), {
        TextColor3 = flashColor
    }):Play()

    TimerLabel.Text = "✓ Selected: " .. scriptName

    task.spawn(function()
        safeWait(0.4)

        -- Fade out UI
        TweenService:Create(TitleLabel, TweenInfo.new(0.25), {TextTransparency = 1}):Play()
        safeWait(0.05)
        TweenService:Create(SubLabel, TweenInfo.new(0.25), {TextTransparency = 1}):Play()
        TweenService:Create(TimerLabel, TweenInfo.new(0.25), {TextTransparency = 1}):Play()
        TweenService:Create(NoteLabel, TweenInfo.new(0.25), {TextTransparency = 1}):Play()
        safeWait(0.2)

        TweenService:Create(Card, TweenInfo.new(0.4, Enum.EasingStyle.Sine), {
            BackgroundTransparency = 1,
            Position = UDim2.new(0.5, -230, 0.5, -200)
        }):Play()
        TweenService:Create(BG, TweenInfo.new(0.4, Enum.EasingStyle.Sine), {
            BackgroundTransparency = 1
        }):Play()

        for i = 24, 0, -3 do
            blur.Size = i
            safeWait(0.025)
        end

        safeWait(0.2)
        SelectorGui:Destroy()
        blur:Destroy()
        safeWait(0.1)

        if scriptName == "Rivals" then
            loadRivalsScript()
        elseif scriptName == "VoidSpam" then
            loadVoidSpamScript()
        end
    end)
end

