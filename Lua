local function CreateTab(name, icon)
    local TabBtn = Instance.new("TextButton")
    TabBtn.Size             = UDim2.new(1,0,0,40)
    TabBtn.BackgroundColor3 = Theme.TabInactive
    TabBtn.BorderSizePixel  = 0
    TabBtn.Text             = icon .. "  " .. name
    TabBtn.TextColor3       = Theme.TextDim
    TabBtn.TextSize         = 13
    TabBtn.Font             = Enum.Font.GothamBold
    TabBtn.TextXAlignment   = Enum.TextXAlignment.Left
    TabBtn.ZIndex           = 12
    TabBtn.Parent           = TabBar
    Instance.new("UICorner", TabBtn).CornerRadius = UDim.new(0,10)

    local TabPad2 = Instance.new("UIPadding")
    TabPad2.PaddingLeft = UDim.new(0,12)
    TabPad2.Parent      = TabBtn

    local ActiveBar = Instance.new("Frame")
    ActiveBar.Size             = UDim2.new(0,3,0.6,0)
    ActiveBar.Position         = UDim2.new(0,-1,0.2,0)
    ActiveBar.BackgroundColor3 = Theme.Accent
    ActiveBar.BorderSizePixel  = 0
    ActiveBar.Visible          = false
    ActiveBar.ZIndex           = 13
    ActiveBar.Parent           = TabBtn
    Instance.new("UICorner", ActiveBar).CornerRadius = UDim.new(1,0)

    local TabContent = Instance.new("ScrollingFrame")
    TabContent.Name                = name .. "Content"
    TabContent.Size                = UDim2.new(1,0,1,0)
    TabContent.BackgroundTransparency = 1
    TabContent.BorderSizePixel     = 0
    TabContent.ScrollBarThickness  = 3
    TabContent.ScrollBarImageColor3 = Theme.Accent
    TabContent.CanvasSize          = UDim2.new(0,0,0,0)
    TabContent.AutomaticCanvasSize = Enum.AutomaticSize.Y
    TabContent.Visible             = false
    TabContent.ZIndex              = 12
    TabContent.Parent              = ContentArea

    local ContentList = Instance.new("UIListLayout")
    ContentList.SortOrder = Enum.SortOrder.LayoutOrder
    ContentList.Padding   = UDim.new(0,6)
    ContentList.Parent    = TabContent

    local ContentPad = Instance.new("UIPadding")
    ContentPad.PaddingTop    = UDim.new(0,12)
    ContentPad.PaddingLeft   = UDim.new(0,10)
    ContentPad.PaddingRight  = UDim.new(0,10)
    ContentPad.PaddingBottom = UDim.new(0,12)
    ContentPad.Parent        = TabContent

    local tabData = {Button=TabBtn, Content=TabContent, ActiveBar=ActiveBar, Name=name}

    TabBtn.MouseButton1Click:Connect(function()
        if ActiveTab == tabData then return end
        if ActiveTab then
            Tween(ActiveTab.Button, {BackgroundColor3=Theme.TabInactive}, 0.2)
            TweenQuick(ActiveTab.Button, {TextColor3=Theme.TextDim})
            ActiveTab.Content.Visible  = false
            ActiveTab.ActiveBar.Visible = false
        end
        ActiveTab = tabData
        Tween(TabBtn, {BackgroundColor3=Color3.fromRGB(30,30,48)}, 0.2)
        TweenQuick(TabBtn, {TextColor3=Theme.Text})
        TabContent.Visible   = true
        ActiveBar.Visible    = true
        TabContent.Position  = UDim2.new(0.05,0,0,0)
        Tween(TabContent, {Position=UDim2.new(0,0,0,0)}, 0.2)
    end)

    TabBtn.MouseEnter:Connect(function()
        if ActiveTab ~= tabData then
            TweenQuick(TabBtn, {BackgroundColor3=Color3.fromRGB(22,22,35)})
        end
    end)
    TabBtn.MouseLeave:Connect(function()
        if ActiveTab ~= tabData then
            TweenQuick(TabBtn, {BackgroundColor3=Theme.TabInactive})
        end
    end)

    TabsData[name] = tabData
    return TabContent
end

