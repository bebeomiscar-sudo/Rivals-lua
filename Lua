local function getAimbotLerpAlpha(dt)
    local sm    = math.clamp(tonumber(aimbot.smoothness) or 2, 0.1, 10)
    local curve = aimbot.aimCurve or "Linear"
    local spd   = 6 / sm
    if curve == "Instant"   then return 1
    elseif curve == "Expo"  then return 1 - math.exp(-(4/sm)*dt)
    elseif curve == "EaseIn" then
        local t = math.clamp(spd*dt,0,1); return t*t
    elseif curve == "EaseOut" then
        local t = math.clamp(spd*dt,0,1); return 1-(1-t)*(1-t)
    elseif curve == "EaseInOut" then
        local t = math.clamp(spd*dt,0,1)
        return t<0.5 and 2*t*t or 1-((-2*t+2)^2)/2
    elseif curve == "Cubic" then
        local t = math.clamp(spd*dt,0,1); return t*t*t
    end
    return math.clamp(spd*dt,0,1)
end

local function clearAimbotLock()
