local function Tween(obj, props, duration, style, direction)
    local t = TweenService:Create(
        obj,
        TweenInfo.new(
            duration or 0.25,
            style or Enum.EasingStyle.Quart,
            direction or Enum.EasingDirection.Out
        ),
        props
    )
    t:Play()
    return t
end

local function TweenQuick(obj, props)
    return Tween(obj, props, 0.15, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
end

