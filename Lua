    SliderKnob.Size             = UDim2.new(0,16,0,16)
    SliderKnob.Position         = UDim2.new(fillPercent,-8,0.5,-8)
    SliderKnob.BackgroundColor3 = Color3.fromRGB(255,255,255)
    SliderKnob.BorderSizePixel  = 0
    SliderKnob.ZIndex           = 14
    SliderKnob.Parent           = Track
    Instance.new("UICorner", SliderKnob).CornerRadius = UDim.new(1,0)

    local KnobStroke = Instance.new("UIStroke")
    KnobStroke.Color     = Theme.Accent
    KnobStroke.Thickness = 2
    KnobStroke.Parent    = SliderKnob

    local isDragging = false

    local function UpdateSlider(inputX)
        local absPos  = Track.AbsolutePosition
        local absSize = Track.AbsoluteSize
        local relX    = math.clamp(inputX - absPos.X, 0, absSize.X)
        local pct     = relX / absSize.X
        local newVal  = math.round(minVal + (maxVal - minVal) * pct)
        Config[configKey] = newVal
        ValueLabel.Text   = tostring(newVal) .. (suffix or "")
        Fill.Size         = UDim2.new(pct,0,1,0)
        SliderKnob.Position = UDim2.new(pct,-8,0.5,-8)
        if callback then callback(newVal) end
    end

    local ClickZone = Instance.new("TextButton")
    ClickZone.Size               = UDim2.new(1,0,1,0)
    ClickZone.BackgroundTransparency = 1
    ClickZone.Text               = ""
    ClickZone.ZIndex             = 15
    ClickZone.Parent             = Track

    ClickZone.MouseButton1Down:Connect(function(x)
        isDragging = true
        UpdateSlider(x)
        Tween(SliderKnob, {Size=UDim2.new(0,20,0,20), Position=UDim2.new(SliderKnob.Position.X.Scale,-10,0.5,-10)}, 0.1)
    end)

    -- Touch support for mobile
    ClickZone.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            isDragging = true
            UpdateSlider(input.Position.X)
        end
    end)
    ClickZone.InputChanged:Connect(function(input)
        if isDragging and input.UserInputType == Enum.UserInputType.Touch then
            UpdateSlider(input.Position.X)
        end
    end)
    ClickZone.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            isDragging = false
            Tween(SliderKnob, {Size=UDim2.new(0,16,0,16)}, 0.1)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if isDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            UpdateSlider(input.Position.X)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            if isDragging then
                isDragging = false
                Tween(SliderKnob, {Size=UDim2.new(0,16,0,16)}, 0.1)
            end
        end
    end)

    Frame.MouseEnter:Connect(function() TweenQuick(Frame, {BackgroundColor3=Color3.fromRGB(22,22,35)}) end)
    Frame.MouseLeave:Connect(function() TweenQuick(Frame, {BackgroundColor3=Theme.Secondary}) end)

    return Frame
end

