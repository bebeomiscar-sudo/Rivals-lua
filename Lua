                if rawget(v, "DeflectCooldown") then rawset(v, "DeflectCooldown", 0.01) end
                if rawget(v, "DeflectDuration") then rawset(v, "DeflectDuration", 0.01) end
            end
        end
        task.wait(0.01)
        pcall(function()
            local Modules = ReplicatedStorage:FindFirstChild("Modules")
            if not Modules then return end
            local lib = Modules:FindFirstChild("ItemLibrary")
                or Modules:FindFirstChild("ItemLibrary", true)
            if not lib then return end
            local ItemLibrary = require(lib)
            if ItemLibrary and ItemLibrary.Items then
                for _, item in pairs(ItemLibrary.Items) do
                    if item.Name and string.find(item.Name:lower(), "katana") then
                        item.DeflectCooldown = 0.01
                        item.DeflectDuration = 0.01
                    end
                end
            end
        end)
